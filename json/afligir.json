{
  "lema": "AFLIGIR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev1041\"><b><u>v.</u></b></dicabrev> </i></font></p>   <b>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"></b>",
  "acepciones": [
    {
      "id": "1.",
      "definicion": "</font> </p>   </b>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "a)",
      "definicion": "</font></b><font   face=\"arial\"> Causar dolor ó molestia física; y en general, Aquejar, atormentar      (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font   face=\"arial\">—</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)      </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«De aquí adelante no padecerán más hambre ni sed,      ni los afligirá el ardor del sol y del estío.»",
              "autor": "<a name=\"autor1044\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Símb.</i> 2. 16, § 2 (R. 6. 321<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Las      enfermedades los afligían y no podían sufrir la destemplanza del cielo.»",
              "autor": "<a name=\"autor1045\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp. </i>11. 25 (R. 30. 339<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«La hambre espantosa que los afligía era un enemigo      más terrible que las armas del Campeador.»",
              "autor": "<a name=\"autor1046\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
              "referencia_obra": "<i><dicautor><a name=\"autor1047\"><font color = \"#FF000\"><u>Cid</u></font></b></dicautor></i> (R. 19. 209<sup>1</sup>) </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Harto      ya de afligir nuestra comarca, | Huyó á nuevo presidio y nueva tierra.»",
              "autor": "<a name=\"autor1048\"><font color = \"#FF000\"><u>Valb.</u></font></b>",
              "referencia_obra": "<i>Bern. </i>5 (R. 17. 194<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Del<i>      </i>áspero caballo no corrige | La furia y gallardía, | Ni con freno le rige,      | Ni con vivas espuelas ya le aflige.»",
              "autor": "<a name=\"autor1049\"><font color = \"#FF000\"><u>Garcil.</u></font></b>",
              "referencia_obra": "<i>canc.</i>      5 (R. 32. 31<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«En la      cerrada noche no cesaron | De afligir con espuelas los caballos.»",
              "autor": "<a name=\"autor1050\"><font color = \"#FF000\"><u>Erc.</u></font></b>",
              "referencia_obra": "<i>Arauc.</i> 12 (R. 17. 50<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">—</font><font face=\"arial\" color=\"#000080\">      </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font   face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«En ninguno de los reinos afligidos de la herejía      ha causado esta bestia infernal tantas inquietudes y tantos males como en      el de Francia.»",
              "autor": "<a name=\"autor1051\"><font color = \"#FF000\"><u>Coloma</u></font></b>",
              "referencia_obra": ", <i>Guerras de los Est. Bajos, </i>1 (R. 28.13<sup>2</sup>).      </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> Entre los místicos, Mortificar (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font   face=\"arial\">—</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)      </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Debemos mucho advertir que el remedio que habemos      dicho de afligir la carne, suele ser provechoso cuando la tentación nace de      la misma carne.»",
              "autor": "<a name=\"autor1053\"><font color = \"#FF000\"><u>Ávila</u></font></b>",
              "referencia_obra": ", <i>Audi</i>, 6 (<i>Míst.</i> 3. 137). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Hicieron que los que antes --- hacían Dios de su vientre, empleando      todos sus cuidados y patrimonios en regalar su carne, la afligiesen y maltratasen      con asperezas y abstinencias.»",
              "autor": "<a name=\"autor1054\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Símb.</i>      2. 30, § 1 (R. 6. 381<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Comiencen      todos á llorar y afligir su carne para satisfacer por las culpas que cometieron      por ella.»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Id. <i>Orac. y consid. </i>3. 2. 1, § 1 (R. 8. 180<sup>2</sup>).      </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Y los que no hicieron culpas graves, para preservarse      de ellas afligían su carne con grandes asperezas.»",
              "autor": "<a name=\"autor1055\"><font color = \"#FF000\"><u>Puente</u></font></b>",
              "referencia_obra": ", <i>Medit. </i>5. 39 (3. 238)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">—</font><font face=\"arial\" color=\"#000080\">      </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font   face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)",
          "id_limpio": "— α α )",
          "definicion": "<i>Refl. </i></font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Y no te empieces | Luégo con extraordinarias |      Penitencias á afligir.»",
              "autor": "<a name=\"autor1056\"><font color = \"#FF000\"><u>Mor.</u></font></b>",
              "referencia_obra": "<i>La mojigata</i>,      3. 2 (R. 2. 408<sup>2</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "2.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Causar dolor ó sentimiento      grande en el ánimo (<i><dicabrev><a name=\"abrev1058\"><b><u>trans.</u></b></dicabrev></i>)<i>.</i>",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</i></font></p>   <font face=\"arial\"></font>   <p ALIGN=\"JUSTIFY\"> <i><font face=\"arial\">—</font></i><i><font face=\"arial\" color=\"#000080\">      </font></i><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"><i> </i></font><font face=\"arial\">)      </font>",
          "id_limpio": "— α )",
          "definicion": "<font face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Mucho más gravemente nos afligían      las caídas de los nuestros que las mismas heridas.»",
              "autor": "<a name=\"autor1059\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Símb</i>. 2. 23, § 1 (R. 6. 346<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Con      estas y otras mil maneras de mofas y dichos la afligían y atormentaban.»",
              "autor": "<a name=\"autor1060\"><font color = \"#FF000\"><u>Yepes</u></font></b>",
              "referencia_obra": ",<i> Vida de Sta. Ter</i>. 1. 12 (<i>Míst. </i>1. 50). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Afligíale vivamente al duque de Parma la falta      grande de dineros con que se hallaba.»",
              "autor": "<a name=\"autor1061\"><font color = \"#FF000\"><u>Coloma</u></font></b>",
              "referencia_obra": ",<i>      Guerras de los Est. Bajos, </i>4 (R. 28. 45<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«El vencedor, con la licencia y libertad que sigue, afligía      todos los vencidos de cualquier edad ó condición que fuesen.»",
              "autor": "<a name=\"autor1062\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp</i>. 6. 24 (R. 30. 183<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">—</font><font face=\"arial\" color=\"#000080\">      </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font   face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«¿Dónde vas, avecilla desdichada? | Dónde puedes      estar afligida?»",
              "autor": "<a name=\"autor1063\"><font color = \"#FF000\"><u>F. de la Torre</u></font></b>",
              "referencia_obra": ", 1, <i>canc</i>.      1 (21). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Anduvieron desterrados por las soledades y desiertos,      pobres, angustiados y afligidos.»",
              "autor": "<a name=\"autor1064\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Adic.      al Mem. med</i>. 19, § 2 (R. 8. 571<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Aquí      la que se vio al pie de la cruz la más afligida de las mujeres, se ve agora      ensalzada sobre los coros de los ángeles.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>.      23 (R. 8. 587<sup>2</sup>). </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— <i>Sup</i>. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«La      primera palabra que habló antes que consolase á su afligidísima madre, y que      encomendase su espíritu al Padre, fue pedirle perdón por aquellos que le crucificaban.»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Id. <i>Símb</i>. 3. 20, § 1 (R. 6. 433<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font   face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>con</i>, para expresar el medio ó instrumento. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«No      se contentaron con veros sentenciado á muerte, sino quisieron también afligir      vuestra ánima santísima con crueles escarnios.»",
              "autor": "<a name=\"autor1065\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Adic. al Mem. med.</i> 16, § 3 (R. 6. 556<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Primero      [mataron] á todos éstos y después al viejo Simeón, para afligirle con ver      tantas muertes de sus hermanos.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>Símb.</i>      2. 25 (R. 6. 351<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">—</font><font face=\"arial\" color=\"#000080\">      </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font   face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)",
          "id_limpio": "— α α )",
          "definicion": "<i>Pas.</i> </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«No se puede pensar género de mal con que España      no fuese afligida.»",
              "autor": "<a name=\"autor1066\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp</i>. 6.      27 (R. 30. 188<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\">      </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Afligido con lo que veía.»",
              "autor": "<a name=\"autor1067\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram</i>."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— </font><font face=\"symbol\">γ</font><font face=\"arial\">      )",
          "id_limpio": "— γ )",
          "definicion": "<i>Absol</i>. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Más aflige la enfermedad,      que alegra la salud.»",
              "autor": "<a name=\"autor1068\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Guía,</i> 1. 29,      § 6 (R. 6. 115<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«No      sólo aflige la indiferencia con que la ignorancia mira la ilustración, sino      también la malignidad con que la envidia la persigue.»",
              "autor": "<a name=\"autor1069\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>Corresp. con Posada</i> (R. 50. 201<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— </font><font face=\"symbol\">δ</font><font face=\"arial\">      )",
          "id_limpio": "— δ )",
          "definicion": "<i>Refl</i>. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«El cura daba voces,      la ventera gritaba, su hija se afligía --- Dorotea estaba confusa --- y doña      Clara desmayada.»",
              "autor": "<a name=\"autor1070\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij.</i> 1. 45 (R. 1. 383<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Afligiósele el corazón por parecerle que no llevaba camino      de remediar tan presto su falta.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>.      1. 8 (R. 1. 270<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Cuando      por mandado de Dios fue [Acab] reprehendido de sus maleficios, humillóse afligindose,      y ayunando, y vistiéndose de cilicio.»",
              "autor": "<a name=\"autor1071\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Orac.      y consid.</i> 3. 2. 1, § 1 (R. 8. 180<sup>2</sup>). </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Sólo      con que digáis, | Sólo con verme afligir, | Que ya no os queréis partir, |      Ya quiero yo que os partáis.»",
              "autor": "<a name=\"autor1072\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>Al pasar      el arroyo</i>, 1. 5 (R. 24. 389<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">—</font><font face=\"arial\" color=\"#000080\">      </font><font face=\"symbol\">α</font><font face=\"arial\" color=\"#000080\"> </font><font face=\"symbol\">α</font><font   face=\"arial\" color=\"#000080\"> </font><font face=\"arial\">)",
          "id_limpio": "— α α )",
          "definicion": "Con <i>de</i>, para      expresar el origen, la causa de la aflicción. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Afligíase      Cecina del mal suceso de sus primeras empresas.»",
              "autor": "<a name=\"autor1073\"><font color = \"#FF000\"><u>Coloma</u></font></b>",
              "referencia_obra": ",<i> Tác. Hist. </i>2. 24 (92). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Más      que el mal suceso, daña | Afligirse mucho dél.»",
              "autor": "<a name=\"autor1074\"><font color = \"#FF000\"><u>Alarcón</u></font></b>",
              "referencia_obra": ", <i>La industria y la suerte</i>, 2. 11 (R. 20. 34<sup>3</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Tan incapaz de envidia como de presunción, ni buscaba alabanzas,      contento con merecerlas, ni se afligía del talento ajeno, siempre ansioso      de comunicar el propio.»",
              "autor": "<a name=\"autor1075\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>Elog. de V.      Rodr.</i> (R. 46. 375<sup>1</sup>). </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— <i><dicautor><a name=\"autor1076\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor></i> </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Afligido      de lo que veía.»",
              "autor": "<a name=\"autor1077\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram.</i>"
            }
          ]
        },
        {
          "id_marcador_html": "</i> </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\">      </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "También se expresa la causa por      medio de un gerundio. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Habiendo      perdido los zarcillos que le dio su amante, se aflige pensando en las reconvenciones      que la esperan.»",
              "autor": "<a name=\"autor1078\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
              "referencia_obra": "<i> Introd. al Parn. esp</i>. 4 (R. 19. 138<sup>1</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "Per. antecl.",
      "definicion": "</b></font><font   face=\"arial\"> (El<i> afregido</i> del <dicautor><a name=\"autor1081\"><font color = \"#FF000\"><u>Canc. de Baena</u></font></b></dicautor> representa la misma pronunciación      vulgar ó dialéctica que aparece en este pasaje: </font><font face=\"arial\"   color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Aunque me afrija y me aburra, | No he de decir, lo que ha habido.»",
          "autor": "<a name=\"autor1082\"><font color = \"#FF000\"><u>Tirso</u></font></b>",
          "referencia_obra": ", <i>El pretendiente al revés</i>, 1. 4 (R. 5. 22<sup>2</sup>).      El cambio de <i>i</i> en <i>e</i> es todavía vulgar en España: </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Un canario aflegío | Ronda mi barrio.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\">      <i>Cantos pop. esp</i>. 1858). — <i>Siglo XV</i>: </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Muy      afligido por la falsa infamia, é por el destierro é perdimiento de bienes,      murió en Valencia del Cid.»",
          "autor": "<a name=\"autor1083\"><font color = \"#FF000\"><u>P. de Guzmán</u></font></b>",
          "referencia_obra": ", <i>Gener.</i>      5 (R. 68. 702<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«En      su vejez fue lanzado | De su alto trono e silla, | E por su fijo, en Sevilla      | Con gran furor desterrado, | Afligido e trabaxado.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>Clar. var. </i>340<i> (Rim. inéd</i>. 322). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Aflitos e molestados | De los reyes de Leon | --- Sacudieron      de sí el yugo.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id.<i> ib.</i> 161 (<i>Rim. inéd</i>.      296). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Non efuses resçebir | Al contrito, | Nin te plega      al afflito | Afflegir.»",
          "autor": "<a name=\"autor1084\"><font color = \"#FF000\"><u>Santill.</u></font></b>",
          "referencia_obra": "p. 40. </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Este de clemençia es silla é reposo, | E de los afflitos muro      é deffensor.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id. p. 110. </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Nin puede ser consolado | El coraçon afflexido.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. p. 350. </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Aragon      | Será afregido, sy non se le omilla.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Canc.      de Baena</i>, p. 14. </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">—<i> Siglo XIV: </i></font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«El      coraçon del justo quando es mas afligido | En las tribulaçiones su ruego es      ante oydo.»",
          "autor": "<a name=\"autor1085\"><font color = \"#FF000\"><u>Pal.</u></font></b>",
          "referencia_obra": "</i>1031 (R. 57. 459<sup>2</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Etim.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Port. <i>affligir,      </i><dicabrev><a name=\"abrev1087\"><b><u>ant.</u></b></dicabrev> <i>affrigir; </i><dicabrev><a name=\"abrev1088\"><b><u>gall.</u></b></dicabrev><i> afrixir;</i> <dicabrev><a name=\"abrev1089\"><b><u>fr.</u></b></dicabrev> <i>affliger; </i><dicabrev><a name=\"abrev1090\"><b><u>it.</u></b></dicabrev> <i>affliggere:</i>      del <dicabrev><a name=\"abrev1091\"><b><u>lat.</u></b></dicabrev> <i>affligere, </i>golpear, derribar, <dicabrev><a name=\"abrev1092\"><b><u>comp.</u></b></dicabrev> de <i>ad, á</i>, y <i>fligere,      </i>herir, golpear, sobre cuyas afinidades en la familia indoeuropea andan      discordes los etimologistas.</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "Conjug.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">En los clásicos      era común el part. <dicabrev><a name=\"abrev1095\"><b><u>adj.</u></b></dicabrev> <i>aflicto </i>por<i> afligido, </i>y aun hoy tiene      cabida en verso. </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Si por los pecados que yo hice, mi Señor fue tan      aviltado y aflicto, ¿cómo dejaré yo de abatirme y despreciarme siendo yo el      mesmo que pequé?»",
          "autor": "<a name=\"autor1096\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
          "referencia_obra": "<i>Orac. y consid. </i>1<i>, lunes en la noche </i>(R. 8.      24<sup>1</sup>)<i>. </i></font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«No hay      linaje de gente más aflicta en todas las naciones del mundo.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\">      Id. <i>Símb.</i> 4. 18, § 2 (R. 6. 524<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Algunos      dellos, que eran infinitos, | Su libertad buscaban revolando; | Otros estaban      míseros y aflitos.»",
          "autor": "<a name=\"autor1097\"><font color = \"#FF000\"><u>Garcil.</u></font></b>",
          "referencia_obra": "<i>égl.</i> 2 (R. 32. 8<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«El cielo al deseo | Del aflicto siempre acude.»",
          "autor": "<a name=\"autor1098\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
          "referencia_obra": "El <i>gallardo español, </i>2 (<i>Com</i>. 1. 30). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Fue inmenso el llanto y plaga lastimera | De la      ciudad aflicta y dolorida»",
          "autor": "<a name=\"autor1099\"><font color = \"#FF000\"><u>Jáur.</u></font></b>",
          "referencia_obra": "<i>Bat. naval      </i>(R. 42. 115<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Pudo      tener oculto | Un tiempo el hecho, y á su aflicta hermana | Entretener con      esperanza vana.»",
          "autor": "<a name=\"autor1100\"><font color = \"#FF000\"><u>Maury</u></font></b>",
          "referencia_obra": ", <i>Dido</i> (R. 67. 175<sup>2</sup>).</font></p>   <font face=\"arial\">    <p ALIGN=\"JUSTIFY\"> </p>   <p ALIGN=\"JUSTIFY\"> </p>   </font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>"
        }
      ],
      "subacepciones": []
    }
  ],
