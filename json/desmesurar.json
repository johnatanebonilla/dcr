{
  "lema": "DESMESURAR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev1842\"><b><u>v.</u></b></dicabrev> </p>   </i></font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Desarreglar, desordenar ó descomponer (<i>trans</i>.)<i>. <dicautor><a name=\"autor1844\"><font color = \"#FF000\"><u>Acad.</u></font></b></dicautor> Dicc. </p>   </i></font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> <i>Refl. </i>Descomedirse, excederse, perder la moderación.",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "Con<i>   con, </i>para expresar la persona á quien se trata sin comedimiento. </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Item, que en las comedias se quite el desmesurarse los   embajadores con los reyes, y que de aquí adelante no le valga la ley del mensajero.»",
              "autor": "<a name=\"autor1846\"><font color = \"#FF000\"><u>Guev.</u></font></b>",
              "referencia_obra": "<i>Diablo Coj. </i>10 (R. 33. 44<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<i><dicautor><a name=\"autor1847\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor>   </i>Descomedido, descortés, atrevido. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«En lo   cual dice dos cosas, una ---otra, que no lo tengan por desmesurado como a hombre que habla   antes de tiempo.»",
              "autor": "<a name=\"autor1848\"><font color = \"#FF000\"><u>León</u></font></b>",
              "referencia_obra": ", <i>Expos. de Job, </i>32 (2. 147). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "c)",
      "definicion": "</b></font><font   face=\"arial\"> <i>Part</i>. Que excede la medida ordinaria, excesivo. </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Aquel filisteazo de Golías que tenía siete codos y medio   de altura, que es una desmesurada grandeza.»",
          "autor": "<a name=\"autor1850\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
          "referencia_obra": "<i>Quii</i>.   2. 1 (R. 1. 407<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Pues hallaba   casa [Morgante] donde cupiese, claro está que no era desmesurada su grandeza.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib.</i> 2. 1 (R. 1. 407<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Las cenizas del cuerpo de Julio César se pusieron sobre una pirámide   de piedra de desmesurada grandeza, á quien hoy llaman en Roma la Aguja de San Pedro.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib</i>. 2. 8 (R. 1. 420<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Vieron que hacia ellos venía un desmesurado jabalí.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib.</i> 2. 34 (R. 1. 477<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«En traje de demonio les pasó [el postillón] por delante tocando en vez   de corneta un hueco y desmesurado cuerno, que un ronco y espantoso són despedía.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib.</i> 2. 34 (R. 1. 478<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Le ceñía y atravesaba un ancho tahalí, también negro, de quien   pendía un demesurado alfanje.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib.</i> 2. 36 (R. 1. 482<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Hecho esto sacó de la vaina un ancho y   desmesurado alfanje.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>. 2. 39 (R. 1. 486<sup>1</sup>).   </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«No se da lugar aun en el estilo de que   hablamos, ni á los pensamientos falsos, ni á las hipérboles desmesuradas.»",
          "autor": "<a name=\"autor1851\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
          "referencia_obra": "<i>Human. castell. Retór.</i> (R. 46. 127<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«La halagaba por todos medios, satisfaciendo hasta sus más   leves antojos, y haciéndola desvanecer con elogios desmesurados.»",
          "autor": "<a name=\"autor1852\"><font color = \"#FF000\"><u>M. de la Rosa</u></font></b>",
          "referencia_obra": "<i>, Is.</i></font><font face=\"arial\" color=\"#0000ff\"> </font><font   face=\"arial\"><i>de <dicautor><a name=\"autor1853\"><font color = \"#FF000\"><u>Solís</u></font></b></dicautor></i>, 1. 2 (4. 203). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Había   adquirido tan desmesurado poder [la casa de Austria], que aspiraba á extender por todas   partes su dominación ó su influjo.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id<i>. Esp. del siglo, </i>3.   1 (5. 169).</p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Per. antecl.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><i>Siglo XV:</i> </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Desmesurarse: <i>immodestus sum.</i>»",
          "autor": "<a name=\"autor1856\"><font color = \"#FF000\"><u>Nebrija</u></font></b>",
          "referencia_obra": ", <i>Vocab</i>. </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Los   alemanes e todos los otros extrangeros se maravillaban de la desmesurada despensa quel rey   hacia.»",
          "autor": "<a name=\"autor1857\"><font color = \"#FF000\"><u>Crón. Juan II</u></font></b>",
          "referencia_obra": ", </i>9. 12 (R. 68. 365<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Como el noble brio de su alto corazon non pudiesse   comportar con paciencia una tan desmesurada manera de responder, dijo ---»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"><i> Crón. Álv. de Luna,</i> 120 (329.) </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«¿Quál pensamiento fue aquel que vos fizo assayar tan feo é   desmesurado atrevimiento?»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Ib</i>. 10 (31). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Pues veo que fis errança | En te ser desmesurado.»",
          "autor": "<a name=\"autor1858\"><font color = \"#FF000\"><u>Canc. de Stúñ.</u></font></b>",
          "referencia_obra": "</i> p. 182. </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«No   puede ser numerada | Mi cuyta desd’aquel día, | Que vi la señora mia | Contra mí   desmessurada.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Santíll. p. 372. </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Nin persona alguna á quien demandasse | Consejo á mi cuyta tan   desmessurada.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id. p. 422. </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Vestro ayre delicado | Quiero levar por escudo, | Non temo con él nin   dudo | Mal desir desmesurado.»",
          "autor": "<a name=\"autor1859\"><font color = \"#FF000\"><u>Canc. de Baena</u></font></b>",
          "referencia_obra": ",</i></font><font   face=\"arial\" color=\"#0000ff\"> </font><font face=\"arial\">p. 228. </p>   <p ALIGN=\"JUSTIFY\">— <i>Siglo XIII</i>: </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Non   cae al rey ser desmesurado en el logar do debe haber mesura.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Cast.   é docum.</i> 11 (R. 51. 113<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«E   como eran omes sin mesura, fueron desmesurados contra el.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Crón.   gen</i>. 3. 19 (248<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Si cosa   desmesurada mandase, debese endereszar por alvedrio de homes bonos.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Part</i>. 3. 4. 24 (2. 409). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Onde   el rey que esto non ficiese mostrarse hie por cobdicioso, et por desmesurado, et aun por   torticero.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Part</i>. 2. 15. 4 (1. 136). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Si mas non la onrrasse serie desmesurado.»",
          "autor": "<a name=\"autor1860\"><font color = \"#FF000\"><u>Berc.</u></font></b>",
          "referencia_obra": "<i>Mil</i>. 140 (R. 57. 108<sup>1</sup>).</p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Etim.",
      "definicion": "</b></font><font   face=\"arial\"> Compuesto del prefijo privativo <i>des</i> y <i>mesura</i>. Port. <i>desmesurar</i>;   <dicabrev><a name=\"abrev1862\"><b><u>prov.</u></b></dicabrev> <i>desmesurar</i>, <i>desmezurar</i>; <dicabrev><a name=\"abrev1863\"><b><u>it.</u></b></dicabrev> <i>dismisurare</i>.</p>   </font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>",
      "ejemplos_citas": [],
      "subacepciones": []
    }
  ],
