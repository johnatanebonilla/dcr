    {
      "id": "Etim.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Port. <i>decretar</i>; <dicabrev><a name=\"abrev1203\"><b><u>fr.</u></b></dicabrev> <i>décréter</i>;   <dicabrev><a name=\"abrev1204\"><b><u>it.</u></b></dicabrev> <i>decretare</i>; <dicabrev><a name=\"abrev1205\"><b><u>lat.</u></b></dicabrev> bajo <i>decretare</i>, derivado de <i>decretum</i>, decreto, <i>decernere</i>,   decidir, compuesto de <i>cernere</i>, cerner, discernir. </p>   <p ALIGN=\"JUSTIFY\"> </p>   <p ALIGN=\"JUSTIFY\"> </p>   </font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>",
