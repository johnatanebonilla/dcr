          "id_limpio": "— α α )",
          "definicion": "Con la <dicabrev><a name=\"abrev449\"><b><u>prep.</u></b></dicabrev> <i>con.</i> RAE </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
