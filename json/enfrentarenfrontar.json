              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Agustí, <i>Mariona   </i>(ed. 1948, p. 83). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
