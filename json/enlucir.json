{
  "lema": "ENLUCIR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev107\"><b><u>v.</u></b></dicabrev></i> </p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>",
  "acepciones": [
    {
