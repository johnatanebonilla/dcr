    {
      "id": "Etim.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Del <dicabrev><a name=\"abrev138\"><b><u>lat.</u></b></dicabrev> <i>inlucere </i>'lucir,   brillar', y éste de <i>in y lucere </i>'brillar', derivado de <i>lux</i>, -cis 'luz'.   Cat. <i>enlluir.</p>   </i></font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
