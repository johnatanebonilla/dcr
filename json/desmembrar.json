{
  "lema": "DESMEMBRAR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev1668\"><b><u>v.</u></b></dicabrev></i> </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Dividir y apartar los miembros del cuerpo, quitar uno ó más miembros (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Los azotan, descoyuntan, desmiembran, despedazan, y abrasan   con planchas de fuego.»",
              "autor": "<a name=\"autor1670\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Guía,</i> 1. 8 (R. 6. 37<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Le desmembraron y despedazaron con diversos   tormentos.»",
              "autor": "<a name=\"autor1671\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp. </i>2. 8 (R. 30. 38<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Desmembraban los cuerpos, abrasaban los brazos   y piernas á vista del dueño que vivía en ellas.»",
              "autor": "<a name=\"autor1672\"><font color = \"#FF000\"><u>B. Argens.</u></font></b>",
              "referencia_obra": "(<dicautor><a name=\"autor1673\"><font color = \"#FF000\"><u>Capm.</u></font></b></dicautor> <i>Teatro</i>, 4. 406). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Era cierto   admirable cosa verle | Saltar y acometer con furia insana, | Desmembrando la gente.»",
              "autor": "<a name=\"autor1674\"><font color = \"#FF000\"><u>Erc.</u></font></b>",
              "referencia_obra": "<i>Arauc</i>. 8 (R. 17. 33<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Descuartiza, desmiembra y desfigura.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>.   14 (R. 17. 57<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Jurando no dejar   cacique alguno | Sin desmembrarlos todos uno á uno.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>.   23 (R. 17. 85<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«¿Donde llevas,   tirano, | Esos pedazos de mi sangre y vida, | Si ya tu propia mano | No ha sido de las   suyas patricida, | Y en arte los desmiembra, | Y cual Medea por la tierra siembra?»",
              "autor": "<a name=\"autor1675\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>Los embustes de Celauro</i>, 3. 1 (R. 24. 104<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Un oso á brazos desmiembra.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\">   Id. <i>Contra valor no hay desdicha, </i>1<i>. </i>13 (R. 41. 5<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«No cuelga en vano aqueste alfanje al hombro, | Que si   parte, si rompe, si desmiembra, | No hay para qué lo diga.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\">   Id. <i>Angél.</i> 20 (<i>Obr. suelt</i>. 2. 358). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«A la pulguina gente más cercana | Piernas y brazos les desmiembra y   quita.»",
              "autor": "<a name=\"autor1676\"><font color = \"#FF000\"><u>Villav.</u></font></b>",
              "referencia_obra": "<i>Mosq</i>. 11 (R. 17. 615<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«A éste barrena, á esotro descabeza, | Y al otro lo   desmiembra pieza á pieza.»",
              "autor": "<a name=\"autor1677\"><font color = \"#FF000\"><u>Valb.</u></font></b>",
              "referencia_obra": "<i>Bern</i>. 10 (R. 17. 247<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Hiere, desmiembra, rompe, quiebra y parte.»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib</i>. 22 (R. 17. 373<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Sin filo ya, ni corte, el hierro aferra, | Y desmiembra los cuerpos sin   herida.»",
              "autor": "<a name=\"autor1678\"><font color = \"#FF000\"><u>Jáur.</u></font></b>",
              "referencia_obra": "<i>Fars</i>. 11 (<dicautor><a name=\"autor1679\"><font color = \"#FF000\"><u>Fern.</u></font></b></dicautor> 7. 317). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Te desmiembren, te partan, te degüellen.»",
              "autor": "<a name=\"autor1680\"><font color = \"#FF000\"><u>D. Gonz.</u></font></b>",
              "referencia_obra": "<i>El murciélago alevoso</i> (R. 61.187<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Ved cuál lleva su garrudo | Y gran frisón Hazaílla, | Desmembrado,   aunque membrudo, | De su cabalgar muy crudo | Y golpazos de la silla.»",
              "autor": "<a name=\"autor1681\"><font color = \"#FF000\"><u>Castillejo</u></font></b>",
              "referencia_obra": "</i>, 2 (R. 32. 167<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Aquel á golpes desmembrado y muerto.»",
              "autor": "<a name=\"autor1682\"><font color = \"#FF000\"><u>Valb.</u></font></b>",
              "referencia_obra": "<i>Bern</i>.   13 (R. 17. 283<sup>1</sup>). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1684\"><b><u>met.</u></b></dicabrev> Dividir y separar cosas que constituyen un todo (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«El se iba mejorando con todo el ejército, por no dar   ocasión, con desmembralle, á que el enemigo ejecutase su intento.»",
              "autor": "<a name=\"autor1685\"><font color = \"#FF000\"><u>Coloma</u></font></b>",
              "referencia_obra": ", <i>Guerras de los Est. Bajos</i>, 5 (R. 28. 53<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Envió á ordenar á Horacio con varios mensajeros que no   partiese aquel día de la Fera, no atreviéndose á desmembrar más el ejército enviando   en su socorro.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>. 7 (R. 28. 93<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Dice que pues heredo | A su hermano y mi padre, y en Toledo   | Mi mayorazgo tiene | Su antigüedad y casa, no conviene | Pudiendo eslabonarla | Con   nuevo parentesco, desmembrarla.»",
              "autor": "<a name=\"autor1686\"><font color = \"#FF000\"><u>Tirso</u></font></b>",
              "referencia_obra": ", <i>El amor médico</i>,   2. 1 (R. 5. 387<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Habiéndole   ofrecido el título de emperador de Italia, respondió que en ella no quería más que lo   que le tocaba, no conviniendo, desmembrar la dignidad imperial.»",
              "autor": "<a name=\"autor1687\"><font color = \"#FF000\"><u>Saav.</u></font></b>",
              "referencia_obra": "<i>Emp</i>. 95 (R. 25. 249<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«La   enseñanza de la ética será imperfecta é incompleta si no abraza toda la doctrina que   los modernos metodistas han desmembrado para adjudicarla á estos tratados.»",
              "autor": "<a name=\"autor1688\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>Trat. de enseñ. Ética</i> (R. 46. 252<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«El rey propuso una nueva alteración en la moneda, y que se   desmembrase el reino de Jaén para darle á uno de sus nietos.»",
              "autor": "<a name=\"autor1689\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
              "referencia_obra": "<i>Guzmán el Bueno </i>(R. 19. 212<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Aunque á la verdad poseo | Bastantes fondos, ya ves, | Si á Plácida   casar puedo | Sin desmembrarlos, ¿qué mal | Me vendrá?»",
              "autor": "<a name=\"autor1690\"><font color = \"#FF000\"><u>Bretón</u></font></b>",
              "referencia_obra": ", <i>Los dos sobrinos, </i>5 1 (1. 42)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Refl</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«La pusieron en la cárcel, con lo cual nos desmembramos todos, y echó   cada uno por su parte.»",
              "autor": "<a name=\"autor1691\"><font color = \"#FF000\"><u>Quev.</u></font></b>",
              "referencia_obra": "<i>Gran Tac</i>. 22 (R. 23. 525<sup>1</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Se iba desmembrando [la superstición de   Mahoma] y partiendo en varias sectas.»",
              "autor": "<a name=\"autor1692\"><font color = \"#FF000\"><u>Rivad.</u></font></b>",
              "referencia_obra": "<i>Cisma</i>, 1.   1 (R. 60. 187<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Mira la parva   parva el desdichado, | Que tanto por instantes se desmiembra, | Que le viene á faltar   para la siembra.»",
              "autor": "<a name=\"autor1693\"><font color = \"#FF000\"><u>Mosq.</u></font></b>",
              "referencia_obra": "</i>4 (R. 17. 585<sup>1</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Desmembraráse el reino castellano.»",
              "autor": "<a name=\"autor1694\"><font color = \"#FF000\"><u>Valb.</u></font></b>",
              "referencia_obra": "<i>Bern.</i> 19 (R. 17. 337<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Chocó el infeliz navío, y dividiéndose en desmembradas piezas,   venció el conjurado piélago ---»",
              "autor": "<a name=\"autor1695\"><font color = \"#FF000\"><u>Tirso</u></font></b>",
              "referencia_obra": ", <i>Del. aprov. </i>fol<i>.   </i>105<sup>2</sup>."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con<i>   de, </i>para señalar el todo de que se separa una parte. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Era ciertamente impolítico desmembrar de la corona aquella dignidad [el   maestrazgo] en el estado en que se hallaban las cosas.»",
              "autor": "<a name=\"autor1696\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
              "referencia_obra": "<i>Gran   Capitán</i> (R. 19. 277<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Refl. </i></font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Comienza á desmembrarse [esta tierra] del otro monte sobredicho.»",
              "autor": "<a name=\"autor1697\"><font color = \"#FF000\"><u>Ocampo</u></font></b>",
              "referencia_obra": ", <i>Crón</i>. 1. 6 (1. 58). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«El haberse apartado y desmembrado el reino de Navarra del de Aragón,   como se hizo los años pasados, tenía puesto en mayor cuidado á don Ramón.»",
              "autor": "<a name=\"autor1698\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp. </i>11. 4 (R. 30. 311<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«La Inglaterra misma cuidó con solícito anhelo, al   celebrarse el tratado de Utrecht, no de que se desmembrasen de la monarquía española sus   ricas posesiones de ultramar, sino de que permaneciesen unidas á la metrópoli.»",
              "autor": "<a name=\"autor1699\"><font color = \"#FF000\"><u>M. de la Rosa</u></font></b>",
              "referencia_obra": ", <i>Esp. del siglo, </i>8. 18 (6. 442)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "<i> Pas</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Siendo partes de la renta pública no pueden ser desmembradas de ella ni   de su administración general.»",
              "autor": "<a name=\"autor1700\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>Instrucc</i>. á <i>la   Junta de Hacienda</i> (R. 50. 78<sup>2</sup>).</p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "Per. antecl.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><i>Siglo XV</i>: </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Fasian les desmenbrar e cortar rrayses de mandragora.»",
          "autor": "<a name=\"autor1703\"><font color = \"#FF000\"><u>Villena</u></font></b>",
          "referencia_obra": "<i>, Arte cis. </i>18 (107).<i> </p>   </i><p ALIGN=\"JUSTIFY\">— <i>Siglo XIII: </i></font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«E   fizol arrastrar [á la reyna doña Bruchilda] a la cola de vna yegua braua fasta que fue   toda desmembrada.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Crón. <dicabrev><a name=\"abrev1704\"><b><u>gen.</u></b></dicabrev></i> 2. 44 (177<sup>1</sup>)<i>.   </i></font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Et esto ficieron porque --- luego que lo   cogiesen en mano, que lo matasen de cruel muerte por ello, rastrándolo et   desmembrándolo.»",
          "autor": "<a name=\"autor1705\"><font color = \"#FF000\"><u>Part.</u></font></b>",
          "referencia_obra": "</i>2. 28. 2 (2. 316). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Mandaron<i> </i>que los despeñasen [á los que facen aleve]   de logar alto porque se desmembrasen.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Part</i>. 2. 22. 24   (2. 218). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Bien mereciera ser desmembrada por   el mal que habia acometido.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Cal. é Dymna </i>(R. 57. 66<sup>1</sup>).   </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Esta ley diz á los judios que non desmembren   las carnes, nin saquen sevo ende.»",
          "autor": "<a name=\"autor1706\"><font color = \"#FF000\"><u>Fuero</u></font></b>",
          "referencia_obra": "Juzgo</i>, 12. 3.   *7 (190<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«El alma fue maldIta, el   cuerpo desnembrado.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Alex</i>. 1749 (R. 57. 201<sup>1</sup>).   </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Cayoron en prision, auienlos desnembrados ---   | Non auie entre todos uno que fuesse sano, | Que non ouies menos el pie o la mano.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Ib</i>. 1445 (R. 57. 192<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Lo que peor le souo ouol, desmembrado.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>lb</i>.   948 (R. 57. 176<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Los unos   desmembrados, los otros desmedridos.»",
          "autor": "<a name=\"autor1707\"><font color = \"#FF000\"><u>Berc.</u></font></b>",
          "referencia_obra": "<i>S. Mill.</i> 413   (R. 57. 78<sup>2</sup>).</p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Etim.",
      "definicion": "</b></font><font   face=\"arial\"> Compuesto de la partícula privativa <i>des</i> y <i>miembro</i>. Port.,   cat., <dicabrev><a name=\"abrev1709\"><b><u>prov.</u></b></dicabrev> <i>desmembrar</i>; <dicabrev><a name=\"abrev1710\"><b><u>fr.</u></b></dicabrev> <i>démembrer</i>; <dicabrev><a name=\"abrev1711\"><b><u>it.</u></b></dicabrev> <i>dismembrare</i>.</p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "Conjug.",
      "definicion": "</b></font><font   face=\"arial\"> Tiene estas formas diptongadas<i>: desmiembr-o, as, a, an; desmiembr-e, es,   e, en; desmiembra tú</i>. En el siguiente pasaje citado por Capmany puede haber errata: </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«El imperio de Roma [después de Diocleciano] se desmembra,   se divide, se deshace, bambolea y cae.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> (<i>Filosof. eloc.</i> p.   490.)</p>   </font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>"
        }
      ],
      "subacepciones": []
    }
  ],
  "etimologia": ""
}