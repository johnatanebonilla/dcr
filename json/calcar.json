    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> Sacar copia de un dibujo, inscripción ó relieve por contacto inmediato      del original con el papel ó la tela á que han de ser trasladados, lo cual      se hace mediante varios procedimientos (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
