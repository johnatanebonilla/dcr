      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Que no se deduce de otra cosa, que no está relacionado con ella, ilógico.",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
