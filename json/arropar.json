              "texto_cita": "«Arroparse con la colcha.»",
              "autor": "<a name=\"autor941\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram.      </i></font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
