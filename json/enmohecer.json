              "autor": "<a name=\"autor373\"><font color = \"#FF000\"><u>Pz. de Ayala</u></font></b>",
              "referencia_obra": ", <i>Luna de miel </i>(ed. 4924<i>, </i>p. 117)."
            }
          ]
