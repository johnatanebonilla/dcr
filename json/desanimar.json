  "introduccion": "--><dicabrev><a name=\"abrev84\"><b><u>v.</u></b></dicabrev></i></font> </p><b>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"></b>",
  "acepciones": [
