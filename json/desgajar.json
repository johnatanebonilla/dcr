{
  "lema": "DESGAJAR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev491\"><b><u>v.</u></b></dicabrev> </p>   </i></font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Dejar el tronco sin una ó más ramas desgarrándolas ó arrancándolas con   violencia (<i><dicabrev><a name=\"abrev493\"><b><u>trans.</u></b></dicabrev></i>)<i>.</i>",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   </i><p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Las puertas le desquiciaban | De noche, y por ir á hurtar   | La fruta, le desgajaban | El pobre árbol.»",
              "autor": "<a name=\"autor494\"><font color = \"#FF000\"><u>Tirso</u></font></b>",
              "referencia_obra": "<i>, El   pretendiente al revés,</i> 1. 8 (R. 5. 25<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Esta empresa lo representa en el árbol coronado que significa el reino,   de quien si tiraren dos manos, aunque sean animadas de una misma sangre, le desgajarán, y   quedará rota y inútil la corona. Saav. <i>Emp</i>. 70 (R. 5. 194<sup>1</sup>).",
              "autor": "",
              "referencia_obra": ""
            },
            {
              "texto_cita": "«Redil y   chozas por delante lleva, | Y la encina firmísima desgaja.»",
              "autor": "<a name=\"autor495\"><font color = \"#FF000\"><u>Lista</u></font></b>",
              "referencia_obra": ", <i>Poes. filosóf.</i> 10 (R. 67. 307<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Desgaja el roble y la robusta encina.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>Idil</i>.   4 (R. 67. 354<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Encendió una gruesa tea de un desolajado pino.»",
              "autor": "<a name=\"autor496\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>Arcadia</i>, 2 (<i>Obr. suelt.</i> 118). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> Desgarrar ó arrancar con violencia la rama del tronco (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«El aire las cargadas ramas mueve, | Que el peso de la nieve   las desgaja.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Garcil, <i>égl</i>. 2 (R. 32. 17<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Aguijan á las armas, desgajando | Las ramas al depósito   obligadas.»",
              "autor": "<a name=\"autor498\"><font color = \"#FF000\"><u>Erc.</u></font></b>",
              "referencia_obra": "<i>Arauc</i>. 2 (R. 17. 8<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Como en Olimpo y Osa el tracio viento --- | Desgaja el duro   ramo, cimbra el tronco ---»",
              "autor": "<a name=\"autor499\"><font color = \"#FF000\"><u>Jáur.</u></font></b>",
              "referencia_obra": "<i>Fars</i>. 2 (<dicautor><a name=\"autor500\"><font color = \"#FF000\"><u>Fern.</u></font></b></dicautor> 7.   35). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Desgajan unos la rama | De que estaba   suspendido.»",
              "autor": "<a name=\"autor501\"><font color = \"#FF000\"><u>M. de la Rosa</u></font></b>",
              "referencia_obra": ", <i>Poes. El castigo del amor</i>   (1. 29)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Pas</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Es evidente el desgajarse la rama con el peso.»",
              "autor": "<a name=\"autor502\"><font color = \"#FF000\"><u>Césp. y Men.</u></font></b>",
              "referencia_obra": "<i>Sold. Pínd.</i> 1. 6 (R. 18. 286<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«A puñados la fruta unos comían --- | Quién huye al repartir la   compañía, | Buscando en lo escondido parte alguna | Donde comer la rama desgajada, | De   las rapaces manos escapada.»",
              "autor": "<a name=\"autor503\"><font color = \"#FF000\"><u>Erc.</u></font></b>",
              "referencia_obra": "<i>Arauc</i>. 36 (R. 17. 131<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>de</i>,   en el sentido de separación. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«De la primera   encina ó roble que se me depare, pienso desgajar otro tronco tal y tan bueno como   aquél.»",
              "autor": "<a name=\"autor504\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij</i>. 1. 8 (R. 1. 269<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Desgajó de una encina un pesado ramo ó tronco.»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib</i>. 1. 8 (R. 1. 269<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Aquella noche la pasaron entre unos árboles, y del uno dellos desgajó   D. Quijote un ramo seco que casi le podía servir de lanza.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\">   Id. <i>ib</i>. 1. 8 (R. 1. 270<sup>1</sup>). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "c)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev506\"><b><u>met.</u></b></dicabrev> Separar con violencia una cosa de aquella con que está trabada ó de   que forma parte (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Con violencia desgajó infinita [el jayán] | La mayor   parte de la excelsa roca.»",
              "autor": "<a name=\"autor507\"><font color = \"#FF000\"><u>Góng.</u></font></b>",
              "referencia_obra": "<i>Polif</i>. (R. 32. 463<sup>1</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Arrojó tantas piedars desde arriba, | Que las   velas dejó como una criba. | Con los terribles ímpetus desgaja | Los anchurosos lienzos   de las naves.»",
              "autor": "<a name=\"autor508\"><font color = \"#FF000\"><u>Villav.</u></font></b>",
              "referencia_obra": "<i>Mosq</i>. 5 (R. 17. 591<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Refl</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Mi rocín, viéndose en aprieto, se esforzó á tirar dos coces, y de   puro flaco, se le desgajaron las ancas, y quedó en el lodo, bien cerca de acabar.»",
              "autor": "<a name=\"autor509\"><font color = \"#FF000\"><u>Quev.</u></font></b>",
              "referencia_obra": "<i>Gran Tac.</i> 2 (R. 23. 488<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Detener de Fortuna la rodaja | A pocos concedió poder divino; | Y si la   cumbre desvanece el tino, | También tal vez la cumbre se desgaja.»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Id.<i> Musa, </i>2<i>, son. </i>16 (R. 69.16<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>de,   </i>en el sentido de separación. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Tomó al   parecer este nombre [el Peñón de Vélez de la Gomera] por hallarse tan cercano á dicha   ciudad, como que solo le dividía de ella un estrecho brazo de mar. que parece haber   desgajado aquel peñasco de los vecinos montes.»",
              "autor": "<a name=\"autor510\"><font color = \"#FF000\"><u>M. de la Rosa</u></font></b>",
              "referencia_obra": ",   <i>Is. de <dicautor><a name=\"autor511\"><font color = \"#FF000\"><u>Solís</u></font></b></dicautor></i>, 1. 25 (4. 274)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Refl</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Así tal vez del Alpe se desgaja | Peñasco altivo en ímpetu furioso.»",
              "autor": "<a name=\"autor512\"><font color = \"#FF000\"><u>Valb.</u></font></b>",
              "referencia_obra": "<i>Bern</i>. 1 (R. 17. 150<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«¿Quién [podrá] un peñasco suspender valiente | De la cima de un   monte desgajado?»",
              "autor": "<a name=\"autor513\"><font color = \"#FF000\"><u>Cald.</u></font></b>",
              "referencia_obra": "<i>La vida es sueño, </i>3. 5 (R. 7.   14<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">γ</font><font face=\"arial\"> )",
          "id_limpio": "— γ )",
          "definicion": "<i>Refl</i>.   </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Desgajarse la ropa es romperse.»",
              "autor": "<a name=\"autor515\"><font color = \"#FF000\"><u>Covarr.</u></font></b>",
              "referencia_obra": "(<dicabrev><a name=\"abrev514\"><b><u>ant.</u></b></dicabrev>) </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "d)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev517\"><b><u>met.</u></b></dicabrev> <i>Refl</i>. Tener una cosa su principio en otra y extenderse desde   ella como la rama desde el tronco. Con <i>de</i>. </font><font face=\"arial\"   color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Cierto sabemos que tienen su nacimiento [aquellos montes] del pedazo de   sierras que ya muchas veces dijimos desgajarse de los montes Pireneos en Roncesvalles, y   duran hasta Galicia.»",
          "autor": "<a name=\"autor518\"><font color = \"#FF000\"><u>Ocampo</u></font></b>",
          "referencia_obra": ", <i>Crón</i>. 1. 6 (1. 58). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Destos montes hacia la parte de mediodía el monte Idubeda,   llamado así de los antiguos, se desgaja.»",
          "autor": "<a name=\"autor519\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
          "referencia_obra": ", <i> Hist. Esp</i>.   1. 3 (R. 30. 3<sup>2</sup>). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "e)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev521\"><b><u>met.</u></b></dicabrev> Aplicado á lo inmaterial (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Desgajarse de la amistad de otro es desasirse con violencia   ó con maña.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> <dicautor><a name=\"autor522\"><font color = \"#FF000\"><u>Covarr.</font></u>"
            }
          ]
        },
        {
          "id_marcador_html": "</u></font></b></dicautor> </p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Dicha primera escena está totalmente desgajada del drama, el cual no   principia en realidad hasta la siguiente.»",
              "autor": "<a name=\"autor523\"><font color = \"#FF000\"><u>M. de la Rosa</u></font></b>",
              "referencia_obra": ", <i>Edipo,   advert. </i>(3. 233). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "f)",
      "definicion": "</b></font><font   face=\"arial\"> <i><dicabrev><a name=\"abrev525\"><b><u>met.</u></b></dicabrev> Refl.</i> Dícese de las cosas que vienen de lo alto con violencia,   y particularmente de la lluvia.",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Comenzó á desgajarse el cielo, no con lluvia, sino con   acequias de agua.»",
              "autor": "<a name=\"autor526\"><font color = \"#FF000\"><u>Espinel</u></font></b>",
              "referencia_obra": ", <i>Escud</i>. 3. 3 (R. 18. 449<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«¿Ves la espuma del mar blanca y crecida | Al   desgajarse del torrente grave?»",
              "autor": "<a name=\"autor527\"><font color = \"#FF000\"><u>Villegas</u></font></b>",
              "referencia_obra": ", <i>Erót.</i> 2. 3, <i>son</i>.   1 (1. 413). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«O no llegará [el correo], ó   vendrá mucho más tarde que el otro, por la copiosa lluvia que se desgaja sin cesar   veinte y cuatro horas ha.»",
              "autor": "<a name=\"autor528\"><font color = \"#FF000\"><u>Isla</u></font></b>",
              "referencia_obra": ", <i>Cart. famil</i>. 1. 255 (R.   15. 519<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Formándose en la   región del aire vapores y nubes muy densas, se resolvieron en copiosísima lluvia, y   desgajándose y cayendo con un ímpetu más violento que el que forma el Nilo ---   inundaron toda la tierra.»",
              "autor": "<a name=\"autor529\"><font color = \"#FF000\"><u>Scío</u></font></b>",
              "referencia_obra": ", <i>Gén</i>. 7. 6, <i>nota</i>."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Fingiéronle arrojado de las altas | Almenas cristalinas por la furia |   De Júpiter airado, y que | --- cual una estrella desgajada | Desde el alto cenit, cayera   en Lemnos.»",
              "autor": "<a name=\"autor530\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>Paraíso perd</i>. (R. 46. 32<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<dicabrev><a name=\"abrev531\"><b><u>met.</u></b></dicabrev> </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Pues feliz el que aquí ve de la cumbre | Del monte   desgajarse la abundancia.»",
              "autor": "<a name=\"autor532\"><font color = \"#FF000\"><u>Iglesias</u></font></b>",
              "referencia_obra": ", <i>égl.</i> 8 (R. 61. 460<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">γ</font><font face=\"arial\"> )",
          "id_limpio": "— γ )",
          "definicion": "No   parece acertado el uso activo que nos ofrece el siguiente lugar: </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Incendio proceloso | Rompe del Etna la abrasada cumbre | Y entre el humo   nubloso | Globos de fuego pálido desgafa.»",
              "autor": "<a name=\"autor533\"><font color = \"#FF000\"><u>Lista</u></font></b>",
              "referencia_obra": ", <i>Poes sagr</i>.   6 (R. 67. 277<sup>2</sup>).</p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "Per. antecl.",
      "definicion": "</font></b><font   face=\"arial\"> <i>Siglo XV</i>: </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Ca ssy mi   lengua del todo desgaja | Rasgada le veo ssu toca de lyno.»",
          "autor": "<a name=\"autor536\"><font color = \"#FF000\"><u>Canc. de Baena</u></font></b>",
          "referencia_obra": "</i>, p. 430<i>. </p>   </i><p ALIGN=\"JUSTIFY\">— <i>Siglo XIV: </i></font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Que   non los dejen estar tanto los pios por facer fasta quel se les comience á quebrar et á   desgajar.»",
