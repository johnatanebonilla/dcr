    },
    {
      "id": ".",
      "definicion": "</i></b></font><i><font   face=\"arial\"> Siglo XV: </font></i><font   face=\"arial\">x </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Encallecer,   hazer callos: <i>calleo</i>, <i>es; obcalleo, es.»</i>",
          "autor": "",
          "referencia_obra": "</i></font><i><font face=\"arial\"> </font></i><font face=\"arial\">Nebr. <i>Vocab.   </i>x </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Encallecerse assí mucho: <i>percalleo,   es.»</i>",
          "autor": "",
          "referencia_obra": "</i></font><i><font face=\"arial\"> </font></i><font face=\"arial\">Id<i>. ib. </i>x </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Encallecido con callos: <i>callosus, a, um</i>.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib</i>. x </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Encallecido en   astucias: <i>callidus, a, um</i>.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>. x </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Callecer desta manera: <i>obcalleo; obcallesco</i>.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id<i>. ib. </i>x </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Callecer, hazer   callos: <i>calleo, es; callesco, is</i>.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id<i>. ib. </i>x </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Se retraxo en un casal do sus manos, llenas de vitorias se   encallecieron podando.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Lucena, <i>Vida Beata,</i> fol. 10 (<i>Dicc.   Aut.</i>). </font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— <i>Siglo XIII:</i></font><i><font face=\"arial\" color=\"#000080\"> </font></i><font face=\"arial\" color=\"#000080\">X"
        },
        {
          "texto_cita": "«Quien la embuelue en los cabellos dela mugier que quier para fazela encallecer aýna.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Alfonso X<i>, Lapidario</i> (ms. 1276-79).</font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
        }
      ],
      "subacepciones": []
