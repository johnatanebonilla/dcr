      "definicion": "</b></font><font   face=\"arial\"> Extensiva y metafóricamente (<i><dicabrev><a name=\"abrev847\"><b><u>trans.</u></b></dicabrev></i>).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
