  "introduccion": "--><dicabrev><a name=\"abrev832\"><b><u>v.</u></b></dicabrev></i> </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Revelar á la autoridad un delito, designando el autor para que sea   castigado y sin ser parte del juicio el denunciador sino por su voluntad. <dicautor><a name=\"autor834\"><font color = \"#FF000\"><u>Acad.</u></font></b></dicautor> <i>Dicc</i>.",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "<i>   Trans</i>.",
          "ejemplos_citas": []
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "Con <dicabrev><a name=\"abrev835\"><b><u>acus.</u></b></dicabrev> de <dicabrev><a name=\"abrev836\"><b><u>pers.</u></b></dicabrev> </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Obliga la ley de la caridad á delatar al culpado, siempre que éste   padece la pena de la pública infamia.»",
              "autor": "<a name=\"autor837\"><font color = \"#FF000\"><u>Núñez</u></font></b>",
              "referencia_obra": ", <i>Emp.</i> 43   (Dicc. <i>Autor</i>.). </p>   <p ALIGN=\"JUSTIFY\">— <i>Refl</i>. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Delatarse   al juez.»",
              "autor": "<a name=\"autor838\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram</i>. </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«¿Cómo he de sufrir que padezca mi amigo por mi culpa? --- No, no; voy   á delatarme, á librar su preciosa vida y á morir.»",
              "autor": "<a name=\"autor839\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>   El delincuente honrado</i>, 2. 7 (R. 46. 88<sup>1</sup>). </p>   <p ALIGN=\"JUSTIFY\">— <i>Part</i>. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Siempre   reserve un oído al delatado; dé espera á la verdad.»",
              "autor": "<a name=\"autor840\"><font color = \"#FF000\"><u>Nieremb.</u></font></b>",
              "referencia_obra": "<i>Dict. reales</i>, 3 (Dicc.<i> Autor.</i>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "Con <dicabrev><a name=\"abrev841\"><b><u>acus.</u></b></dicabrev> de cosa. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Delatar un crimen al juez.»",
              "autor": "<a name=\"autor842\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram</i>.   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Delató [Annese] inmediatamente al pueblo la   propuesta, y mandó ahorcar en el acto al que la había traído.»",
              "autor": "<a name=\"autor843\"><font color = \"#FF000\"><u>A. Saav.</u></font></b>",
              "referencia_obra": "<i>Masan.</i> 2.16 (5. 243). </p>   <p ALIGN=\"JUSTIFY\">— <i>Part</i>. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«La   nueva, que delatada </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Por Timónides oíste, </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Fue industria, con que asegura </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Que de buscarle se olviden.»",
              "autor": "<a name=\"autor844\"><font color = \"#FF000\"><u>Cald.</u></font></b>",
              "referencia_obra": "<i>Argenis y Poliarco</i>, 1. 16 (R. 7. 442<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<i>Intrans</i>.   <dicautor><a name=\"autor845\"><font color = \"#FF000\"><u>Salvá</u></font></b></dicautor>, <i>Dicc</i>., apunta que los antiguos dijeron alguna vez </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Delatar de sí mismo»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> por<i> delatarse</i>."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">γ</font><font face=\"arial\"> )",
          "id_limpio": "— γ )",
          "definicion": "Con <i>de</i>,   para denotar crimen. Lat. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«deferre de   parricidio.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«A este   mismo tiempo le delató en la misma curia de tales delitos y excesos.»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Cornejo, <i>Crón. de S. Franc.</i> 3. 1. 21 (Dicc. <i>Autor.</i>). </p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
    },
    {
