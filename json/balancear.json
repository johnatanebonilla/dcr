    {
      "id": "a)",
      "definicion": "</font><font face=\"arial\"   color=\"#0000ff\"> </font></b><font face=\"arial\">Dar ó hacer balances (<i>intrans</i>.). Se   dice especialmente del buque cuando toma un movimiento de oscilación hacia uno y otro de   sus costados. <i>Dicc. Marít</i>. </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Al   frondoso </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Bosque no da [el viento] descanso, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Y su penacho umbroso </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Balancea con   silbo sonoroso.»",
          "autor": "<a name=\"autor611\"><font color = \"#FF000\"><u>Arriaza</u></font></b>",
          "referencia_obra": ", <i>oda</i> 5 (R. 67. 65<sup>1</sup>)."
        }
      ],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "También se usa como <i>refl</i>. <dicautor><a name=\"autor612\"><font color = \"#FF000\"><u>Acad.</u></font></b></dicautor> <i>Dicc</i>. La nave se balancea. </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b>",
          "ejemplos_citas": []
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev614\"><b><u>met.</u></b></dicabrev> </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Balancear en la duda.»",
          "autor": "<a name=\"autor615\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
          "referencia_obra": "<i>Gram.</i> </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
        }
