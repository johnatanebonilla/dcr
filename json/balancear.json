    {
      "id": "c)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev617\"><b><u>met.</u></b></dicabrev> Vacilar, dudar, estar perplejo (<i>intrans</i>.). </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Al oír estas palabras responde sin balancear, como fiel   observador de la ley de Dios.»",
          "autor": "<a name=\"autor618\"><font color = \"#FF000\"><u>Scío</u></font></b>",
