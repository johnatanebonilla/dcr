          "referencia_obra": "</font><font face=\"arial\"> Alfar. 1. 2. 4 (<i>Dicc. Aut</i>.).</p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>"
