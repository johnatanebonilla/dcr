    {
      "id": "Per. antecl.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><i>Siglo XV</i>: </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Dios --- </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Vos abrigue syn tardar </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Pues á mi me dessabriga<i>.»</i>",
          "autor": "<a name=\"autor1147\"><font color = \"#FF000\"><u>Canc. de Baena</u></font></b>",
          "referencia_obra": "</i>,<i> </i>p. 159. </p>   <p ALIGN=\"JUSTIFY\">—<i> Siglo XIII. </i></font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Per   lo que ella puede esta desabrigada.</font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> <i>Se </i>lo quemás fuego serie ella folgada.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Alex</i>. 2189 (R. 57. 214</font><sup>2</sup><font face=\"arial\">).</p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
