{
  "lema": "AGUERRIDO, A.",
  "categoria_gramatical": "adj.",
  "introduccion": "--><dicabrev><a name=\"abrev1\"><b><u>adj.</u></b></dicabrev></font> </i></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</font></b><font   face=\"arial\"> Ejercitado en la guerra, hecho á la guerra. </font><font face=\"arial\"   color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«El guerrero que tenía contra sí estaba también acostumbrado á   pelear, mandaba soldados aguerridos, y sobre todo no sabía ceder.»",
          "autor": "<a name=\"autor3\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
          "referencia_obra": "<i>R. de Lauria </i>(R. 19. 230<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Quería con la fuerza de la armada poner en brida ciento   cincuenta mil hombres aguerridos y ya en rebelión abierta.»",
          "autor": "<a name=\"autor4\"><font color = \"#FF000\"><u>Saav.</u></font></b>",
          "referencia_obra": "<i>Masan. </i>2. 10 (5. 208). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Vence al   ejército sardo, el más aguerrido de Italia.»",
          "autor": "<a name=\"autor5\"><font color = \"#FF000\"><u>M. de la Rosa</u></font></b>",
          "referencia_obra": ", <i>Esp</i>.   <i>del siglo</i>, 6<i>. </i>5 (6<i>. </i>17). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Los   mal disciplinados paisanos fueron fácilmente arrollados por las tropas aguerridas del   enemigo.»",
          "autor": "<a name=\"autor6\"><font color = \"#FF000\"><u>Toreno</u></font></b>",
          "referencia_obra": ", <i>Hist.</i> 4 (R. 64. 91<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Penetró, pues, en España al frente de un aguerrido   ejército.»",
          "autor": "<a name=\"autor7\"><font color = \"#FF000\"><u>Mesonero</u></font></b>",
          "referencia_obra": ", <i>Mem. de un setentón</i>, 1<i>. </i>3   (61)."
        }
      ],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\"><i>— </i></font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "Admite un <dicabrev><a name=\"abrev8\"><b><u>compl.</u></b></dicabrev> con <i>en. </i></font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Aguerrido en   combates.»",
              "autor": "<a name=\"autor9\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram.</i> </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Aguerrido en las batallas.»",
              "autor": "<a name=\"autor10\"><font color = \"#FF000\"><u>Salvá</u></font></b>",
              "referencia_obra": ", <i>Gram. </i></font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
