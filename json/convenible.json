{
  "lema": "CONVENIBLE.",
  "categoria_gramatical": "adj.",
  "introduccion": "--><dicabrev><a name=\"abrev1479\"><b><u>adj.</u></b></dicabrev></i>      </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Conveniente (<dicabrev><a name=\"abrev1481\"><b><u>ant.</u></b></dicabrev>).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "<i>Absol</i>. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Entre los tiempos      de la oración, el más convenible es el de la media noche.»",
              "autor": "<a name=\"autor1482\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Orac. y consid.</i> 2. 1, § 10 (R. 8. 109<sup>1</sup>) </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Aunque      no estoy aparejado para celebrar cada día, yo trabajaré de recibir los misterios      divinos en los tiempos convenibles.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib.</i>      4. 3 (R. 11. 423<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Las      circunstancias convenibles | Que acreditan los éxtasis, que suelen | Indicios      ser de santidad notoria, | En los tuyos se hallaron.»",
              "autor": "<a name=\"autor1483\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Poes. suelt.</i> (R. 1. 710<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Ya sospecho | Que buscarle es remedio convenible.»",
              "autor": "<a name=\"autor1484\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>Servir á señor discreto</i>, 2. 13 (R. 52. 82<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font   face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>á</i>. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Más convenible fuera      aquesta suerte | A los cansados años de mi vida.»",
              "autor": "<a name=\"autor1485\"><font color = \"#FF000\"><u>Garcil.</u></font></b>",
              "referencia_obra": "<i>égl.</i> 1 (R. 32. 5<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«La      edad que es convenible | Al que la guerra mantiene, | Esa misma le conviene      | Al amador apacible | Requebrado.»",
              "autor": "<a name=\"autor1486\"><font color = \"#FF000\"><u>Castillejo</u></font></b>",
              "referencia_obra": ", 1, <i>Serm. de amores</i> (R. 32. 154<sup>2</sup>).      </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Yo quedaré en mi entereza, | No procurando imposibles,      | Sino casos convenibles | A nuestra naturaleza.»",
              "autor": "<a name=\"autor1487\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>La entretenida</i>, 3 (<i>Com</i>. 2. 240). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«El      salir es imposible, | Y á mi honor es convenible | Quitar ese mal encuentro.»",
              "autor": "<a name=\"autor1488\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>El molino,</i> 1. 6 (R. 24. 24<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p>   <p ALIGN=\"JUSTIFY\"> <font   face=\"arial\">— </font><font face=\"symbol\">γ</font><font face=\"arial\"> )",
          "id_limpio": "— γ )",
          "definicion": "Con <i>para</i>. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Entrambos buscan      medio convenible | Para que aquel terrible furor loco | Les empeciese poco.»",
              "autor": "<a name=\"autor1489\"><font color = \"#FF000\"><u>Garcil.</u></font></b>",
              "referencia_obra": "<i>égl.</i> 2 (R. 32. 18<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Tomada      oportunidad é tiempo convenible para pelear, él les hacía cierta é indubitable      la victoria.»",
              "autor": "<a name=\"autor1490\"><font color = \"#FF000\"><u>Comend. Griego</u></font></b>",
              "referencia_obra": ", <i>Lab.</i> 139 (56<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Busca tiempo convenible para estar contigo, y piensa á menudo      en los beneficios de Dios.»",
              "autor": "<a name=\"autor1491\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Imit</i>. 1.      20 (R. 11. 388<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Le      pareció convenible y necesario, así para el aumento de su honra, como para      el servicio de su república, hacerse caballero andante.»",
              "autor": "<a name=\"autor1492\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij.</i> 1. 1 (R. 1. 257<sup>2</sup>). </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> Tratándose del precio, Cómodo, razonable, moderado. </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«El retrato que vuestra merced tiene, ya se le      tengo comprado al pintor por precio convenible.»",
          "autor": "<a name=\"autor1494\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
          "referencia_obra": "<i>Pers</i>. 4. 7 (R. 1. 671<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«El      tenía conocimiento --- en una casa donde se daba de comer razonablemente y      á precio convenible.»",
          "autor": "<a name=\"autor1495\"><font color = \"#FF000\"><u>Espinel</u></font></b>",
          "referencia_obra": ", <i>Escud</i>. 1.      9 (R. 18. 399<sup>1</sup>). </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "c)",
      "definicion": "</b></font><font   face=\"arial\"> Aplicado á persona, Tratable, que se conviene fácilmente con los      demás. </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«¿Bien quisieras este día | Irte de aquí? —      ¡Sí, por Dios! | — Pues véte; que yo diré | A tu gente, cuando llegue,      | Que tu rescate me entregue. | — Dices bien. (En buena fe, | Que el      gigante es convenible.)»",
          "autor": "<a name=\"autor1497\"><font color = \"#FF000\"><u>Cald.</u></font></b>",
          "referencia_obra": "<i>La puente de Mantible</i>, 2. 11 (R. 7. 214<sup>2</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Per. antecl.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><i>Siglo XV</i>:      </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Ya quando la muerte viene en oportuno y convenible      tiempo: conviene saber, que tome al hombre como fiel xpiano deue estar.»",
          "autor": "<a name=\"autor1500\"><font color = \"#FF000\"><u>Mena</u></font></b>",
          "referencia_obra": ", <i>Coron</i>. 18 (12<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Los      cabellos parescian oro, distintos et dispuestos en orden muy convenible.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Vis. delect</i>. 1. 3 (R. 36. 346<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Dende, sacar a luengo lo tierno de los pechos e partillo en      partes convenibles.»",
          "autor": "<a name=\"autor1501\"><font color = \"#FF000\"><u>Villena</u></font></b>",
          "referencia_obra": ", <i>Arte cis.</i> 8      (58). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«El tiene agora consigo dos flores | Que son convenibles      para su talante.»",
          "autor": "<a name=\"autor1502\"><font color = \"#FF000\"><u>Canc. de Baena</u></font></b>",
          "referencia_obra": ",</i> p. 299.      </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— <i>Siglo XIV</i>: </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Las      razones susodichas non eran convenibles, nin razonables, nin verdaderas.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> L. de Ayala, <i>Caza</i>, 24 (<i>Bibl. venat.</i> 3. 261). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Lo traería luego á vistas con el rey de Aragon      en lugar que se pudiese faser é fuese convenible.»",
          "autor": "<a name=\"autor1503\"><font color = \"#FF000\"><u>Crón. Fern. IV</u></font></b>",
          "referencia_obra": ",</i> 12 (R. 66. 135<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«E      tovo que estos enterramientos que non eran convenibles.»",
          "autor": "<a name=\"autor1504\"><font color = \"#FF000\"><u>Crón. Sancho IV</u></font></b>",
          "referencia_obra": "</i>, 3 (R. 66. 74<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Bien      puedo cabalgar ó cazar en la manera conuenible.»",
          "autor": "<a name=\"autor1505\"><font color = \"#FF000\"><u>J. Man.</u></font></b>",
          "referencia_obra": "<i>Lib. de los est.</i> 1. 59 (R. 51. 311<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Otrossi      que en casa de nuestro ssennor el rey que sea puesto tal alguazil que sea      para ello convenibre.»",
          "autor": "<a name=\"autor1506\"><font color = \"#FF000\"><u>C. de L. y C.</u></font></b>",
          "referencia_obra": "</i> 1. 358). </font></p>   <p ALIGN=\"JUSTIFY\"> <font face=\"arial\">— <i>Siglo XIII</i>: </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Débelo      él mismo leer --- sevendo asentado en aquel logar do suele oir los pleytos      ó en otro que sea convenible para ello.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Part</i>.      3. 22. 5 (2. 658). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Et estas cosas --- puédelas el patriarca ó el      primado bendecir en la eglesia, et aun en su posada ó en otro lugar que sea      convenible para tales cosas facer.»",
          "autor": "<a name=\"autor1507\"><font color = \"#FF000\"><u>Part.</u></font></b>",
          "referencia_obra": "</i>      1. 5. 14 (1. 205). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Si el vendedor non es convenible, deve dar fiador      al comprador.»",
          "autor": "<a name=\"autor1508\"><font color = \"#FF000\"><u>Fuero</u></font></b>",
          "referencia_obra": "Juzgo</i>, 5. 4. 2 (85).      </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Et deve seer guardada [la ley] segund la costumbre      de la cibdad, é deve seer convenible al logar é al tiempo.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\">      <i>Ib</i>. 1. 2. 4 (5). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Non es      convenible cosa que él entienda de fazer gran roydo, mas de fazer la ley.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\">      <i>Ib</i>. 1. 1. 2 (2). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Entendemos      cosa por muy necesaria que --- feciemos las cosas que eran convenibles á Dios.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\">      <i>Ib. preámb.</i> 1 (II). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Non      llama glotonia comer omne fartura | En horas conuenibles pora mantener natura.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\">      <i>Alex</i>. 2217 (R. 57. 215<sup>1</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Etim.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Derivado de <i>convenir</i>;      <dicabrev><a name=\"abrev1510\"><b><u>it.</u></b></dicabrev> <i>convenevole</i>; <dicabrev><a name=\"abrev1511\"><b><u>port.</u></b></dicabrev> <i>conveniavel;</i> <dicabrev><a name=\"abrev1512\"><b><u>prov.</u></b></dicabrev> <i>convenable</i>,      <i>convenhable</i>; <dicabrev><a name=\"abrev1513\"><b><u>fr.</u></b></dicabrev> <i>convenable</i>.</font></p>   <font face=\"arial\" color=\"#0000ff\"><b>    <p ALIGN=\"JUSTIFY\"> </p>   <p ALIGN=\"JUSTIFY\"> </p>   </b></font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>",
      "ejemplos_citas": [],
      "subacepciones": []
    }
  ],
