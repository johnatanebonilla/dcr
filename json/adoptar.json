    {
      "id": "Etim.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Fr. <i>adopter;      </i><dicabrev><a name=\"abrev1714\"><b><u>it.</u></b></dicabrev> <i>adottare: </i>del <dicabrev><a name=\"abrev1715\"><b><u>lat.</u></b></dicabrev> <i>adoptare, </i><dicabrev><a name=\"abrev1716\"><b><u>comp.</u></b></dicabrev> de <i>ad, </i>á<i>,      </i>y<i> opto, </i>escoger, esto es, escoger para sí.</font></p>   <font face=\"arial\">    <p> </p>   <p> </p>   </font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>",
