              "autor": "<a name=\"autor975\"><font color = \"#FF000\"><u>Espinel</u></font></b>",
              "referencia_obra": ", <i>Escud.</i> 2. 13 (R. 18. 442<sup>2</sup>).</p>   </font><font face=\"arial\" color=\"#800080\"><b><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
