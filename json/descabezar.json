{
  "lema": "DESCABEZAR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev1007\"><b><u>v.</u></b></dicabrev></i> </font></p>   <b><p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"></b>",
  "acepciones": [
    {
      "id": "1.",
      "definicion": "</font> </p>   </b><p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "a)",
      "definicion": "</font><font face=\"arial\"   color=\"#0000ff\"> </font></b><font face=\"arial\">Quitar ó cortar la</font><font   face=\"arial\" color=\"#0000ff\"> </font><font face=\"arial\">cabeza (<i><dicabrev><a name=\"abrev1010\"><b><u>trans.</u></b></dicabrev></i>).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Concertábamos irnos á tierra de moros, pidiendo por amor   de Dios, para que allá nos descabezasen.»",
              "autor": "<a name=\"autor1011\"><font color = \"#FF000\"><u>Sta. Ter.</u></font></b>",
              "referencia_obra": "<i>Vida</i>,   1 (R. 53. 24<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Hizo descabezar en   la prisión á un caballero que era su repostero mayor.»",
              "autor": "<a name=\"autor1012\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp.</i></font><font   face=\"arial\" color=\"#0000ff\"> </font><font face=\"arial\">17. 4 (R. 30. 501<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Murió confortando al hermano, que descabezaron.»",
              "autor": "<a name=\"autor1013\"><font color = \"#FF000\"><u>Mend.</u></font></b>",
              "referencia_obra": "<i>Guerra de Granad.</i> 1 (R. 21.</font><font face=\"arial\"   color=\"#0000ff\"> </font><font face=\"arial\">78<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Dorotea consoló á Sancho Panza diciéndole, que cada y cuando que   pareciese haber sido verdad que su amo hubiese descabezado al gigante, le prometía, en   viéndose pacífica en su reino, de darle el mejor condado que en él hubiese.»",
              "autor": "<a name=\"autor1014\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij</i>. 1. 35 (R. 1. 353<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Me es á mí más fácil imitarle en esto, que no en hender gigantes,   descabezar serpientes, matar endriagos, desbaratar ejércitos ---»",
              "autor": "",
              "referencia_obra": "</font><font   face=\"arial\"> Id. <i>ib</i>. 1. 25 (R. 1. 313<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Comenzó [D. Quijote] á llover cuchilladas sobre la titerera morisma,   derribando á unos, descabezando á otros.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>ib</i>. 2.   26 (R. 1. 460<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«A éste barrena,   á esotro descabeza, </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Y al otro lo desmiembra pieza a pieza.»",
              "autor": "<a name=\"autor1015\"><font color = \"#FF000\"><u>Valb.</u></font></b>",
              "referencia_obra": "<i> Bern.</i> 10 (R. 17. 247<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Pas.</i> </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Nos cuentan los escritores </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Verdaderos </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> De muy altos consejeros </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Y riquísimos privados, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Que por sólo   seis dineros </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Han sido descabezados.»",
              "autor": "<a name=\"autor1016\"><font color = \"#FF000\"><u>Castillejo</u></font></b>",
              "referencia_obra": ", 3,<i> Vida   de corte</i> (R. 32. 225<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "<i> <dicautor><a name=\"autor1017\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor> </i></font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Sempronio y Parmeno quedan descabezados en la plaza como públicos   malhechores.»",
              "autor": "<a name=\"autor1018\"><font color = \"#FF000\"><u>Celest.</u></font></b>",
              "referencia_obra": "</i> 13 (R. 3. 57<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«El cuerpo de san Dionisio, después de asado y descabezado,   tomó su propria cabeza en los brazos, y la llevó al lugar donde agora está sepultado.»",
              "autor": "<a name=\"autor1019\"><font color = \"#FF000\"><u>Gran.</u></font></b>",
              "referencia_obra": "<i>Símb.</i> 5. 2. 19, § 1 (R. 6. 611<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Los de Puna viéndose atropellados de este modo por los   extraños, insultados por sus enemigos naturales, preso su señor y descabezados sus   caciques, acudieron á las armas.»",
              "autor": "<a name=\"autor1020\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
              "referencia_obra": "<i>Pizarro </i>(R.   19. 316<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<dicabrev><a name=\"abrev1021\"><b><u>met.</u></b></dicabrev> </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«De este arte le descabezas </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> La libertad cuando empiezas, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Y lo dejas   atajado, </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Dándole mate ahogado </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Entre medias de sus piezas.»",
              "autor": "<a name=\"autor1022\"><font color = \"#FF000\"><u>Castillejo</u></font></b>",
              "referencia_obra": ", 3 (R. 32. 210<sup>1</sup>). </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1024\"><b><u>met.</u></b></dicabrev> Quitar la parte superior ó la punta (<i><dicabrev><a name=\"abrev1025\"><b><u>trans.</u></b></dicabrev></i>).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "Descabezar un árbol, un madero, una aguja. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Descubriéronle   desde lejos que con una hoz en la mano iba descabezando vides.»",
              "autor": "<a name=\"autor1026\"><font color = \"#FF000\"><u>Gracián</u></font></b>",
              "referencia_obra": ",<i> Heroe</i>, 6 (1. 658. <i>Dicc. Autor.</i>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i><dicautor><a name=\"autor1027\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor></i> </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Mira aquel preciado de lindo ó aquel lindo de los más preciados, cómo   duerme con bigoteras, torcidas de papel en las guedejas y el copete, sebillo en las manos   y guantes descabezados.»",
              "autor": "<a name=\"autor1028\"><font color = \"#FF000\"><u>Guev.</u></font></b>",
              "referencia_obra": "<i>Diablo Coj.</i> 2 (R.   33. 23<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<i>Refl</i>.   En especial, Desgranarse las espigas de las mieses. <dicautor><a name=\"autor1029\"><font color = \"#FF000\"><u>Acad.</u></font></b></dicautor> <i>Dicc.</i> </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b>",
          "ejemplos_citas": []
        }
      ]
    },
    {
      "id": "c)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1031\"><b><u>met.</u></b></dicabrev> Hacer el principio de una cosa, salir de él (<i><dicabrev><a name=\"abrev1032\"><b><u>trans.</u></b></dicabrev></i>) (<dicabrev><a name=\"abrev1033\"><b><u>fam.</u></b></dicabrev>).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Se dice de los perezosos é indevotos que dejan descabezar   la misa para oírla.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> <i>Dicc. Autor</i>."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<i>Descabezar el sueño</i>: dormir un breve rato el que tiene mucho sueño. </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Esta mujer desvariando está; espera un poco hasta que   descabece un sueño, que ella ciertamente despierta está soñando.»",
              "autor": "<a name=\"autor1034\"><font color = \"#FF000\"><u>Villalobos</u></font></b>",
              "referencia_obra": ", <i>Anfitrión</i> (R. 36. 473<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Ya no hay quien sin sacar los pies de los estribos,   arrimado á su lanza, sólo procure descabezar, como dicen, el sueño, como lo hacen los   caballeros andantes.»",
              "autor": "<a name=\"autor1035\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij</i>. 2. 1 (R. 1. 407<sup>1</sup>).   </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "d)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1037\"><b><u>met.</u></b></dicabrev> Hablando de malos asos, Vencerlos, generalmente rodeando hasta pasar por   el punto en que comienzan (<i><dicabrev><a name=\"abrev1038\"><b><u>trans.</u></b></dicabrev></i>). </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Y   para descabezar los tales pasos se veían en muchos trabajos.»",
          "autor": "<a name=\"autor1039\"><font color = \"#FF000\"><u>Garcil.</u></font></b>",
          "referencia_obra": "<i> Hist. de la Flor.</i> 2. 2. 17 (<i>Dicc. Autor.</i>). </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "e)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1041\"><b><u>Milit.</u></b></dicabrev> Vencer ó salvar un obstáculo un puente, un desfiladero, teniendo la   cabeza de la columna al otro lado (<i><dicabrev><a name=\"abrev1042\"><b><u>trans.</u></b></dicabrev></i>). <dicautor><a name=\"autor1043\"><font color = \"#FF000\"><u>Almirante</u></font></b></dicautor>,<i> Dicc. milit.</i> </font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "f)",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><dicabrev><a name=\"abrev1045\"><b><u>Milit.</u></b></dicabrev> Poner las primeras   hileras, al preparar una marcha de flanco, en la nueva dirección á vanguardia ó   retaguardia (<i><dicabrev><a name=\"abrev1046\"><b><u>trans.</u></b></dicabrev></i>). <dicautor><a name=\"autor1047\"><font color = \"#FF000\"><u>Acad.</u></font></b></dicautor> <i>Dicc.</i> </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b>",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "g)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1049\"><b><u>met.</u></b></dicabrev> Tocar la cabeza ó extremo de una cosa en otra; dícese de las hazas ó   tierras que terminan en otra ó se extienden hasta ella (<i>intrans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "Con <i>con</i>,   para expresar la tierra con que otra confina. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Al   levante viene á descabezar con la tierra que llaman de los Bacallaos.»",
              "autor": "<a name=\"autor1050\"><font color = \"#FF000\"><u>Garcil.</u></font></b>",
              "referencia_obra": "<i>Hist. de la Flor</i>. 1. 2 (<i>Dicc. Autor.</i>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>en</i>,   en sentido análogo. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Descabezar un terreno en   otro.»",
              "autor": "<a name=\"autor1051\"><font color = \"#FF000\"><u>Terreros</u></font></b>",
              "referencia_obra": ". </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "2.",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1053\"><b><u>met.</u></b></dicabrev> <i>Refl.</i> Perder la cabeza, calentarse la cabeza en averiguar algo   sin lograrlo. </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Descabezarse con, en una   dificultad.»",
          "autor": "<a name=\"autor1054\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
          "referencia_obra": "<i>Gram. </i></font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Descabezarse en acertar.»",
          "autor": "<a name=\"autor1055\"><font color = \"#FF000\"><u>Salvá</u></font></b>",
          "referencia_obra": ", <i>Gram.</i></font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "3.",
      "definicion": "</b></font><font   face=\"arial\"> Deshacer el encabezamiento que han hecho los pueblos (<i><dicabrev><a name=\"abrev1057\"><b><u>trans.</u></b></dicabrev></i>). <dicautor><a name=\"autor1058\"><font color = \"#FF000\"><u>Acad.</u></font></b></dicautor> <i>Dicc</i>.</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "Per. antecl.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><i>Siglo XV</i>: </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Si hovieren de dar una pieza de oro, ú dos ó tres, ó   cinco ó diez, que puedan dar entre ellas una quebrada, ó soldada, ú descabezada de las de   Segovia.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Recop. </i>5. 18. 2, año 1491 (<i>Dicc. Autor</i>.   Según Cantos Benítez en su <i>Escrutinio</i>, 15. 17, citado por Clemencín, <i>descabezada</i> vale <i>recortada</i>.). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Mucha morisma vi   descabeçada.»",
          "autor": "<a name=\"autor1061\"><font color = \"#FF000\"><u>Mena</u></font></b>",
          "referencia_obra": ", <i>Lab</i>. 149 (60<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Des cabeçó a su padre por amores del rey Minos de   Creta.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> Id. <i>Coron. </i>11 (9<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«La su buena adarga toda era ya cortada, é fecha piezas, é la espiga de   la espada dorada á hora de quebrar é descabezar.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Crón.   P. Niño</i>, p. 41. </font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— <i>Siglo XIV</i>: </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Et   descabezó de estos almohades los que pudo aver.»",
          "autor": "<a name=\"autor1062\"><font color = \"#FF000\"><u>Alf. XI</u></font></b>",
          "referencia_obra": "</i>, 214 (R. 66. 310<sup>2</sup>). </font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— <i>Siglo XIII:</i> </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Fueron   presos de los espartanos, é los tenian encerrados para los escabezar.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Cast. é docum. </i>77 (R. 51. 209<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«El rey Herodes mandó descabezar á Santiago, hermano de   S. Juan Evangelista, en Jerusalem.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Anales toledanos</i> (<i>Esp.   sagr.</i> 23. 382). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Descabezó»",
          "autor": "<a name=\"autor1063\"><font color = \"#FF000\"><u>Scío</u></font></b>",
          "referencia_obra": "). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Escabezados»",
          "autor": "<a name=\"autor1064\"><font color = \"#FF000\"><u>Scío</u></font></b>",
          "referencia_obra": "). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«E a dellos embió allen la mar e   fizolos descabeçar alla.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Crón. <dicabrev><a name=\"abrev1065\"><b><u>gen.</u></b></dicabrev></i> 3. 3 (212<sup>3</sup>).   </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«E sy non se querien tornar a la su seta descabeçaualos.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Ib</i>. 2. 39 (174<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Mandólos todos descabezar porque con el su auer non   ayudasen a sus enemigos.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Ib</i>. 1. 35 (17<sup>1</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Salió [Remus] de la cibdat sobre los muros, et   descabezólo por ende sobre ellos.»",
          "autor": "<a name=\"autor1066\"><font color = \"#FF000\"><u>Part.</u></font></b>",
          "referencia_obra": "</i> 3. 28. 16 (2.   716). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Ves lo que me fizo, esta mujer ---   liévala et descabézala.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Cal. é Dymna</i></font><font   face=\"arial\" color=\"#0000ff\"> </font><font face=\"arial\">(R. 51. 63<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«E al que embarga el tu rreynado descabeçalo.»",
          "autor": "<a name=\"autor1067\"><font color = \"#FF000\"><u>Boc. de oro</u></font></b>",
          "referencia_obra": "</i>, 2 (Knust, 108). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Su acusar falsamientre de tal cosa que semeie, que devia seer   descabeszado ---»",
          "autor": "<a name=\"autor1068\"><font color = \"#FF000\"><u>Fuero</u></font></b>",
          "referencia_obra": "Juzgo</i>, 5. 7. 10 (96). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Hy el siervo que se ayunta con la mugier que levó por   fuerza, deve seer descabezado.»",
          "autor": "",
          "referencia_obra": "</font><font face=\"arial\"> <i>Ib.</i> 3. 3. 8 (54). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Si fuesses sabidor, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Faries descabezar luego el   traedor.»",
          "autor": "<a name=\"autor1069\"><font color = \"#FF000\"><u>Alex.</u></font></b>",
          "referencia_obra": "</i> 2329 (R. 57. 218<sup>2</sup>). </font><font   face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Derranchó pora el, quisol descabezar.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Ib</i>. 552 (R. 57. 164<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Que si se levantasse, que serie mal maiado, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> O por escarmentar otros serie   descabezado.»",
          "autor": "<a name=\"autor1070\"><font color = \"#FF000\"><u>Berc.</u></font></b>",
          "referencia_obra": "<i> S. Dom. </i>711 (R. 57. 62<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Se tenien por muertos e por descabezados.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>S. Mill</i>. 205 (R. 57. 71<sup>1</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Mandó --- </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Que lo descabezassen, non pasassen por al.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> Id. <i>S. Laur.</i> 45 (R. 57. 91<sup>2</sup>). </font><font face=\"arial\"   color=\"#000080\">"
        },
        {
          "texto_cita": "«Quantos ninyos fallar podredes, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Todos los descabeçedes.»",
          "autor": "",
          "referencia_obra": "</font><font   face=\"arial\"> <i>Reyes de or.</i></font><font face=\"arial\" color=\"#0000ff\"> </font><font   face=\"arial\">(R. 57. 319<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
        },
        {
          "texto_cita": "«Los   moros e las moras vendenr non los podremos: Que los descabeçemos nada non ganaremos.»",
          "autor": "<a name=\"autor1071\"><font color = \"#FF000\"><u>Cid</u></font></b>",
          "referencia_obra": ",</i> 620 (R. 57. 9<sup>1</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
        }
      ],
      "subacepciones": []
    },
