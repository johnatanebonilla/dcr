    {
      "id": "Pros.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Sin embargo de pronunciarse   baúl, parece que en el verbo no se disuelve la combinación <i>bau: embáula. </i>Así se   halla en el pasaje siguiente: </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«¿Quieres   apostar, señor, </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Que los monsiures caídos </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Nos embaulan, ofendidos </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> De su afrenta y tu valor?»",
          "autor": "<a name=\"autor619\"><font color = \"#FF000\"><u>Tirso</u></font></b>",
