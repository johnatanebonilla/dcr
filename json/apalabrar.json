          "ejemplos_citas": [
            {
              "texto_cita": "«De aquí resultó la vista entre los dos generales, que se apalabró      para el día siguiente, y se verificó en Riobamba.»",
              "autor": "<a name=\"autor660\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
