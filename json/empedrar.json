{
  "lema": "EMPEDRAR.",
  "categoria_gramatical": "v.",
  "introduccion": "--><dicabrev><a name=\"abrev1674\"><b><u>v.</u></b></dicabrev></i> </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>",
  "acepciones": [
    {
      "id": "a)",
      "definicion": "</b></font><font   face=\"arial\"> Cubrir el suelo, dejándolo más o menos llano, de piedras ajustadas unas   con otras (<i><dicabrev><a name=\"abrev1676\"><b><u>trans.</u></b></dicabrev></i>).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> ) </font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"></font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«Este Craso fue el que abrió y empedró el camino y calzada   más famosa de España.»",
              "autor": "<a name=\"autor1677\"><font color = \"#FF000\"><u>Mariana</u></font></b>",
              "referencia_obra": ", <i>Hist. Esp</i>. 3. 11 (R. 30.   72<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Abrieron y empedraron en el   Andalucía el camino real que desde Córdoba iba hasta Écija.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\">   Id. <i>ib.</i> 3. 23 (R. 30. 84<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Bien   puedes mandar mañana </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Que te empiedren el zaguán; </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Que al són que los frenos   tascan </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Llevan el compás los pies.»",
              "autor": "<a name=\"autor1678\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>El mayor   imposible, </i>2. 9 (R. 34. 474<sup>1</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Quien   traza la casa es Dios, </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Esteban es quien la empiedra.»",
              "autor": "<a name=\"autor1679\"><font color = \"#FF000\"><u>Ledesma</u></font></b>",
              "referencia_obra": ", <i>Conc. esp. </i>pte. 1ª p. 177. </font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Don Godofre el   heredado, </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Hijo de Dardín Dardeña, </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Desempedrando la calle, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Los hígados nos empiedra.»",
              "autor": "<a name=\"autor1680\"><font color = \"#FF000\"><u>Góng.</u></font></b>",
              "referencia_obra": "<i>rom,</i> 48 (R. 32. 521<sup>3</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i><dicautor><a name=\"autor1681\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor></i> </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Son estrechas y oscuras [las calles de Oviedo], aunque limpias y muy   bien empedradas.»",
              "autor": "<a name=\"autor1682\"><font color = \"#FF000\"><u>Jovell.</u></font></b>",
              "referencia_obra": "<i>Corresp. con Posada </i>(R. 50.   190<sup>2</sup>). </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Aquellas calles estrechas,   tortuosas y costaneras apenas podían decirse empedradas.»",
              "autor": "<a name=\"autor1683\"><font color = \"#FF000\"><u>Mesonero</u></font></b>",
              "referencia_obra": ", <i>Mad. <dicabrev><a name=\"abrev1684\"><b><u>ant.</u></b></dicabrev> </i>1, p. 90."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con   <i>de, </i>para denotar la clase de piedra. </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Empedrar   de adoquines.»",
              "autor": "<a name=\"autor1685\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram. </i></font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«Empedrar de guijarros.»",
              "autor": "<a name=\"autor1686\"><font color = \"#FF000\"><u>Salvá</u></font></b>",
              "referencia_obra": ", Gram. </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Había hecho un corral para su oficina, y empedrádole o   enlosádole de unas losas grandes que había traído a cuestas.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\">   Sig<i>. Hist. de la ord. de S. Jer. </i>3. 2. 8 (<i>Dicc. Autor.</i>)<i>. </i></font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\"> — a ) Con <i>con</i>, en sentido análogo. </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Empedrar con adoquines.»",
              "autor": "<a name=\"autor1687\"><font color = \"#FF000\"><u>Acad.</u></font></b>",
              "referencia_obra": "<i>Gram.</i>   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Empedrar con guijarros.»",
              "autor": "<a name=\"autor1688\"><font color = \"#FF000\"><u>Salvá</u></font></b>",
              "referencia_obra": ", <i>Gram</i>. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Esta es una   calle: empedrada está, como las de Nápoles, con lavas que ha vomitado ese volcán   vecino.»",
              "autor": "<a name=\"autor1689\"><font color = \"#FF000\"><u>Mor.</u></font></b>",
              "referencia_obra": "<i>Obr. póst</i>. 1, p. 366 </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "b)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1691\"><b><u>met.</u></b></dicabrev> Poner sobre un objeto cosas que le cubran a la manera que el empedrado   cubre el suelo (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "Con <i>con.</i>   </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Hallaron --- a Sanchica cortando un torrezno   para empedrarle con huevos y dar de comer al paje.»",
              "autor": "<a name=\"autor1692\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij.</i>   2. 50 (R. 1. 510<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i> <dicautor><a name=\"autor1693\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor></i> </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«No medre yo, si no son anillos de oro y muy de oro, y empedrados con   peIras blancas como una cuajada, que cada una debe de valer un ojo de la cara.»",
              "autor": "<a name=\"autor1694\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
              "referencia_obra": "<i>Quij.</i> 2. 21 (R. 1. 447<sup>2</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>de</i>.   </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Está empedrando de pan </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Su escudilla, y   yo perezco.»",
              "autor": "<a name=\"autor1695\"><font color = \"#FF000\"><u>Lope</u></font></b>",
              "referencia_obra": ", <i>S. Diego de Alcalá</i>, 3 (R. 52. 528<sup>2</sup>).   </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Entre vuelta y juego empedré la faldriquera   de mendrugos.»",
              "autor": "<a name=\"autor1696\"><font color = \"#FF000\"><u>Quev.</u></font></b>",
              "referencia_obra": "<i>Gran Tac. </i>15 (R. 23. 512<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i>Part</i>. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Su traje, sobre cuerpo desnudo, una manta de fino algodón, enriquecida   con varias joyas y pendientes, de que traía también empedradas las orejas y los   labios.»",
              "autor": "<a name=\"autor1697\"><font color = \"#FF000\"><u>Solís</u></font></b>",
              "referencia_obra": ", <i>Conq. de Méj.</i> 2. 8 (R. 28. 242<sup>1</sup>).   </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "c)",
      "definicion": "</b></font><font   face=\"arial\"> <dicabrev><a name=\"abrev1699\"><b><u>met.</u></b></dicabrev> Dícese particularmente en lo literario de las cosas que se usan o   ponen con mucha frecuencia. (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α )",
          "definicion": "Con <i>de.   </i></font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Se dejan llevar del deseo de parecer   sabios y profundos empedrando de sentencias el razonamiento más simple y más común.»",
              "autor": "<a name=\"autor1700\"><font color = \"#FF000\"><u>Capm.</u></font></b>",
              "referencia_obra": "<i>Filosof. eloc. </i>2. 2 (300)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font   face=\"arial\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "<i><dicautor><a name=\"autor1701\"><font color = \"#FF000\"><u>Part.</u></font></b></dicautor></i> </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Aquel estilo exagerado, empedrado de antítesis y sutilezas, que llegó   a ser común en España en el mismo siglo de Cervantes.»",
              "autor": "<a name=\"autor1702\"><font color = \"#FF000\"><u>Clem.</u></font></b>",
              "referencia_obra": "<i>Coment.   </i>2<i>, </i>p. 239. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Todo Virgilio está, por   decirlo así, empedrado de versos de esta especie.»",
              "autor": "<a name=\"autor1703\"><font color = \"#FF000\"><u>Lista</u></font></b>",
              "referencia_obra": ", <i>Ensayos</i>,   2. p. 44. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Levantó la voz Masanielo, y en un   largo y extravagantísimo discurso, empedrado de sandeces y de ideas luminosas, de frases   chabacanas y de períodos elocuentes, de humildad seráfica y de satánica soberbia,   habló ---»",
              "autor": "<a name=\"autor1704\"><font color = \"#FF000\"><u>A. Saav.</u></font></b>",
              "referencia_obra": "<i>Masan. </i>1. 17 (5. 128). </font><font   face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«No hay en nuestro idioma ni las muchas consonantes de que   están empedradas las palabras de las lenguas del norte, ni las vocales de sonido   incierto, confuso o nasal, que deslucen otros idiomas.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> M. de   la Rosa, <i>Anot. a la Poét</i>. 3. 10 (1. 160). </font><font face=\"arial\"   color=\"#000080\">"
            },
            {
              "texto_cita": "«La más áspera voz, oscura y bronca, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> De duras consonantes   empedrada, </font><font face=\"symbol\">|</font><font face=\"arial\"   color=\"#000080\"> Halla en sus versos favorable asilo.»",
              "autor": "",
              "referencia_obra": "</font><font face=\"arial\"> Id. <i>Poét.</i>   2 (1. 102)."
            }
          ]
        },
        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "Con <i>con.</i>   </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Publicó [Rafael de Torres] en Génova la   historia de aquella sublevación en latín crespo e hinchado, poniendo pomposos discursos   en boca de los personajes, y empedrando la narración con sentencias y apotegmas   políticos.»",
              "autor": "<a name=\"autor1705\"><font color = \"#FF000\"><u>A. Saav.</u></font></b>",
              "referencia_obra": "<i>Masan. pról. </i>(5, xx). </font></p>   <p ALIGN=\"JUSTIFY\"><font face=\"arial\" color=\"#800080\"><b></b>"
            }
          ]
        }
      ]
    },
    {
      "id": "d)",
      "definicion": "</b></font><font   face=\"arial\"> En el siguiente pasaje el <dicabrev><a name=\"abrev1707\"><b><u>part.</u></b></dicabrev> significa Clavado como las piedras que   forman un empedrado: </font><font face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Si aquí nos saltea el   hielo, quedaremos empedrados en estas aguas.»",
          "autor": "<a name=\"autor1708\"><font color = \"#FF000\"><u>Cerv.</u></font></b>",
          "referencia_obra": "<i>Pers</i>.   2. 17 (R. 1. 615<sup>1</sup>).</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Per. antecl.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\"><i>Siglo XV:</i> </font><font   face=\"arial\" color=\"#000080\">",
      "ejemplos_citas": [
        {
          "texto_cita": "«Esta calle es muy poblada y toda empedrada.»",
          "autor": "<a name=\"autor1711\"><font color = \"#FF000\"><u>Gonz. Clav.</u></font></b>",
          "referencia_obra": "p. 32.</font></p>   <p ALIGN=\"JUSTIFY\"><b><font face=\"arial\" color=\"#800080\"></b>"
        }
      ],
      "subacepciones": []
    },
    {
      "id": "Etim.",
      "definicion": "</font><font   face=\"arial\" color=\"#0000ff\"> </font></b><font face=\"arial\">Compuesto de <i>en, </i>que   denota colocación, superposición, y <i>piedra. </i>Port., <dicabrev><a name=\"abrev1713\"><b><u>cat.</u></b></dicabrev> <i>empedrar.</i></font></p>   <p><b><font face=\"arial\" color=\"#800080\">",
      "ejemplos_citas": [],
      "subacepciones": []
    },
    {
      "id": "Conjug.",
      "definicion": "</font><font face=\"arial\"   color=\"#0000ff\"> </font></b><font face=\"arial\">Tiene estas formas diptongadas: <i>empiedr-o,   as, a, an; empiedr-e, es, e, en; empiedra tú.</i></font></p>   <font face=\"arial\" color=\"#0000ff\"><b><p ALIGN=\"JUSTIFY\"> </p>   <p ALIGN=\"JUSTIFY\"> </p>   </b></font><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br><br></body></html>\u0000</b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b></b>",
      "ejemplos_citas": [],
      "subacepciones": []
    }
  ],
