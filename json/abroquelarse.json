            },
            {
              "texto_cita": "«Danle combates interés y olvido, </font><font face=\"symbol\">|</font><font face=\"arial\" color=\"#000080\"> Y      de fe y esperanza se abroquela.»",
              "autor": "<a name=\"autor562\"><font color = \"#FF000\"><u>Quev.</u></font></b>",
              "referencia_obra": "<i>Musa </i>7,      <i>son</i>. 4 (R. 69. 248<sup>2</sup>)."
            }
          ]
