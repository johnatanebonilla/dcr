    {
      "id": "2.",
      "definicion": "</b></font><font   face=\"arial\"> Canjear, intercambiar mercancías (<i>trans</i>.).",
      "ejemplos_citas": [],
      "subacepciones": [
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">α</font><font face=\"arial\"> )</font>",
          "id_limpio": "— α )",
          "definicion": "<font   face=\"arial\" color=\"#000080\"> X</font>",
          "ejemplos_citas": [
            {
              "texto_cita": "«En Santo Domingo no hay quien no salga a rescatar   perlas.»",
              "autor": "<a name=\"autor1249\"><font color = \"#FF000\"><u>Arciniegas</u></font></b>",
              "referencia_obra": ", <i>Biogr. del Caribe, </i>1. 3 (p. 58)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">—</font><font face=\"symbol\"> α</font><font face=\"arial\"> </font><font face=\"symbol\">α</font><font face=\"arial\"> )",
          "id_limpio": "— α α )",
          "definicion": "Con la <dicabrev><a name=\"abrev1250\"><b><u>prep.</u></b></dicabrev> <i>con</i>, que indica el medio.   + </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Sacan los indios bárbaros estas vainas como   cosa preciosa, para rescatar con ellas cuchillos, tijeras y otras menudencias.»",
              "autor": "<a name=\"autor1251\"><font color = \"#FF000\"><u>Cobo</u></font></b>",
              "referencia_obra": ", <i>Hist. Nuevo Mundo, </i>1. 6. 90 (R. 91. 272<sup>1</sup>)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β β )",
          "definicion": "Con <i>por</i>, que especifica el objeto de   intercambio. Además con <i>en, </i>que señala el lugar. </font><font face=\"arial\"   color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Envió algunas cartas con soldados, y por su caudillo a Gómez Arias, a   rescatar en las islas vecinas mantenimientos por ropa.»",
              "autor": "<a name=\"autor1252\"><font color = \"#FF000\"><u>Capm.</u></font></b>",
              "referencia_obra": "<i>Teatro   </i>(4. 393)."
            }
          ]
        },
        {
          "id_marcador_html": "</p>   <p ALIGN=\"JUSTIFY\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "<i>Absol</i>.   + </font><font face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«No hay cosa que más apetezcan [los indios,   que el hierro]; y así, cuando salen de paz a rescatar, no quieren en cambio de sus   mercaderías otra cosa que cuchillos.»",
              "autor": "<a name=\"autor1253\"><font color = \"#FF000\"><u>Cobo</u></font></b>",
              "referencia_obra": ", <i>Hist. Nuevo   Mundo,</i> 1. 3. 43 (R. 91. 152<sup>1</sup>).</p>   </font><b><font face=\"arial\" color=\"#800080\"><p ALIGN=\"JUSTIFY\"></b>"
            }
          ]
        }
      ]
