        {
          "id_marcador_html": "</font></p><p ALIGN=\"JUSTIFY\">   <font face=\"arial\">— </font><font face=\"symbol\">β</font><font face=\"arial\"> )",
          "id_limpio": "— β )",
          "definicion": "La   causa del sobresalto se expresa con <i>de</i>,<i> con</i>,<i> por</i>. </font><font   face=\"arial\" color=\"#000080\">",
          "ejemplos_citas": [
            {
              "texto_cita": "«Se alarmó de, con, por mi llegada.»",
              "autor": "<a name=\"autor1490\"><font color = \"#FF000\"><u>Baralt</u></font></b>",
              "referencia_obra": ", <i>Dicc. Galic</i>. </font><font face=\"arial\" color=\"#000080\">"
            },
            {
              "texto_cita": "«Herrera,   apasionado toda su vida por la condesa de Gelves --- le consagró una pasión fogosa,   tierna y constante, pero acompañada de tal respeto y tal decoro que el pudor no podía   alarmarse de ella.»",
              "autor": "<a name=\"autor1491\"><font color = \"#FF000\"><u>Quint.</u></font></b>",
