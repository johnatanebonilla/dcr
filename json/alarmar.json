              "texto_cita": "«Hago estrépito, se alarman </font><font face=\"symbol\">|</font><font   face=\"arial\" color=\"#000080\"> Todos.»",
              "autor": "<a name=\"autor1489\"><font color = \"#FF000\"><u>Mor.</u></font></b>",
              "referencia_obra": "<i>La mojigata</i>,<i>   </i>3. 10 (R. 2. 412<sup>2</sup>)."
            }
