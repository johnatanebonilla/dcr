              "autor": "<a name=\"autor1522\"><font color = \"#FF000\"><u>Erc.</u></font></b>",
              "referencia_obra": "<i> Arauc.</i> 31 (R. 17. 116<sup>2</sup>).</font><font   face=\"arial\" color=\"#000080\"> X"
